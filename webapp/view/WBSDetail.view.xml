<mvc:View
    controllerName="z.bts.buildtrack551.controller.WBSDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Page title="{parts: [{path: 'WbsName'}], formatter: '.formatWbsDetailTitle'}" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <IconTabBar id="idIconTabBarWBS" class="sapUiResponsiveContentPadding" select=".onTabSelect">
                <items>
                    <IconTabFilter icon="sap-icon://hint" text="{i18n>siteInfoTab}" key="infoTab">
                        
                        <form:SimpleForm 
                            editable="{viewData>/editMode}"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                            columnsXL="2" columnsL="2" columnsM="1"
                            singleContainerFullSize="false">
                            <form:toolbar>
                                <Toolbar>
                                    <Title text="{i18n>workItemDetails}" />
                                    <ToolbarSpacer />
                                    <Button id="btnEditWbs" icon="sap-icon://edit" text="{i18n>edit}" press=".onEditWbs" visible="{= !${viewData>/editMode} }" />
                                    <Button id="btnSaveWbs" icon="sap-icon://save" text="{i18n>save}" type="Emphasized" press=".onSaveWbs" visible="{viewData>/editMode}" />
                                    <Button id="btnCancelWbs" icon="sap-icon://sys-cancel" text="{i18n>cancel}" press=".onCancelWbs" visible="{viewData>/editMode}" />
                                </Toolbar>
                            </form:toolbar>
                            <form:content>
                                
                                <core:Title text="{i18n>identification}" />
                                
                                <Label text="{i18n>name}" design="Bold" />
                                <VBox width="100%">
                                    <Input id="inWbsName" value="{WbsName}" visible="{viewData>/editMode}" />
                                    <Text text="{WbsName}" visible="{= !${viewData>/editMode} }" />
                                </VBox>

                                <Label text="{i18n>wbsCode}" />
                                <Text text="{WbsCode}" />

                                <core:Title text="{i18n>schedulePlannedVsActual}" />

                                <Label text="{i18n>plannedStart}" />
                                <VBox width="100%">
                                    <DatePicker id="inWbsStartDate" class="readonly-datepicker" value="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" visible="{viewData>/editMode}" />
                                    <Text text="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" visible="{= !${viewData>/editMode} }" />
                                </VBox>

                                <Label text="{i18n>plannedEnd}" />
                                <VBox width="100%">
                                    <DatePicker id="inWbsEndDate" class="readonly-datepicker" value="{path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" visible="{viewData>/editMode}" />
                                    <Text text="{path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" visible="{= !${viewData>/editMode} }" />
                                </VBox>

                                <Label text="{i18n>actualStart}" />
                                <Text text="{path: 'StartActual', formatter: '.formatActualDate'}" />

                                <Label text="{i18n>actualEnd}" />
                                <Text text="{path: 'EndActual', formatter: '.formatActualDate'}" />

                                <core:Title text="{i18n>metricsAndStatus}" />

                                <Label text="{i18n>quantity}" visible="{= ${ParentId} !== '00000000-0000-0000-0000-000000000000' &amp;&amp; ${ParentId} !== null &amp;&amp; ${ParentId} !== '' }" />
                                <VBox width="100%" visible="{= ${ParentId} !== '00000000-0000-0000-0000-000000000000' &amp;&amp; ${ParentId} !== null &amp;&amp; ${ParentId} !== '' }">
                                    <Input id="inWbsQuantity" 
                                           value="{path: 'Quantity', formatter: '.formatQuantityInt'}" 
                                           description="{UnitCode}" 
                                           visible="{viewData>/editMode}" />
                                    <ObjectNumber
                                        visible="{= !${viewData>/editMode} }"
                                        number="{
                                            path: 'Quantity',
                                            type: 'sap.ui.model.type.Float',
                                            formatOptions: { minFractionDigits: 0, maxFractionDigits: 0, groupingEnabled: true }
                                        }"
                                        unit="{UnitCode}"
                                        state="None" />
                                </VBox>

                                <Label text="{i18n>status}" />
                                <VBox width="100%">
                                    <ObjectStatus 
                                        text="{path: 'Status', formatter: '.formatWbsStatusText'}"
                                        class="statusBadgeNoWrap"
                                        state="{path: 'Status', formatter: '.formatWbsStatusState'}"
                                        inverted="true" />
                                </VBox>

                            </form:content>
                        </form:SimpleForm>

                        <!-- Location Info -->
                        <form:SimpleForm
                            editable="{viewData>/editMode}"
                            layout="ResponsiveGridLayout"
                            title="{i18n>workLocation}"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                            columnsXL="2" columnsL="2" columnsM="1"
                            singleContainerFullSize="false"
                            class="sapUiSmallMarginTop"
                            visible="{= !!${locationModel>/LocationName} || ${viewData>/editMode} }">
                            <form:content>
                                <core:Title text="{i18n>location}" />

                                <Label text="{i18n>locationName}" design="Bold" required="true" />
                                <VBox width="100%">
                                    <Input id="inLocName" value="{locationModel>/LocationName}" visible="{viewData>/editMode}" liveChange=".onLocationNameLiveChange" />
                                    <Text text="{locationModel>/LocationName}" visible="{= !${viewData>/editMode} }" />
                                </VBox>



                                <core:Title text="{i18n>positionMetric}" />

                                <Label text="{i18n>horizontalRange}" required="true" />
                                <VBox width="100%">
                                    <HBox visible="{viewData>/editMode}">
                                        <Input id="inLocStart" value="{locationModel>/PosStart}" width="45%" type="Number" description="m" liveChange=".onLocRangeChange" />
                                        <Text text=" — " class="sapUiTinyMarginBeginEnd sapUiTinyMarginTop" />
                                        <Input id="inLocEnd" value="{locationModel>/PosEnd}" width="45%" type="Number" description="m" liveChange=".onLocRangeChange" />
                                    </HBox>
                                    <Text text="{locationModel>/PosStart} m → {locationModel>/PosEnd} m" visible="{= !${viewData>/editMode} }" />
                                </VBox>

                                <Label text="{i18n>verticalRange}" required="true" />
                                <VBox width="100%">
                                    <HBox visible="{viewData>/editMode}">
                                        <Input id="inLocBot" value="{locationModel>/PosBot}" width="45%" type="Number" description="m" liveChange=".onLocRangeChange" />
                                        <Text text=" — " class="sapUiTinyMarginBeginEnd sapUiTinyMarginTop" />
                                        <Input id="inLocTop" value="{locationModel>/PosTop}" width="45%" type="Number" description="m" liveChange=".onLocRangeChange" />
                                    </HBox>
                                    <Text text="{locationModel>/PosBot} m → {locationModel>/PosTop} m" visible="{= !${viewData>/editMode} }" />
                                </VBox>
                            </form:content>
                        </form:SimpleForm>

                        <!-- Dependencies Section -->
                        <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.DependencyList" type="XML" />

                    </IconTabFilter>
                    
                    <IconTabFilter id="idDailyLogTab" key="dailyLogTab" icon="sap-icon://activity-assigned-to-goal" text="{i18n>dailyLogTab}" visible="{path: 'ParentId', formatter: '.isChildNode'}">
                        <!-- Fragment được include trực tiếp — không cần lazy load -->
                        <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.DailyLog" type="XML"/>
                    </IconTabFilter>
                    <IconTabFilter id="idWorkSummaryTab" icon="sap-icon://manager-insight" text="{i18n>workSummaryTab}" key="workSummaryTab">
                         <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.WorkSummary" type="XML" />
                    </IconTabFilter>
                    <IconTabFilter id="idApprovalLogTab" icon="sap-icon://approvals" text="{i18n>approvalLogTab}" key="approvalLogTab">
                         <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.ApprovalLog" type="XML" />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>