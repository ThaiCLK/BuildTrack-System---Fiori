<mvc:View
    controllerName="z.bts.buildtrack.controller.WBSDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"> <Page title="WBS Detail: {wbs_name}" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <IconTabBar id="idIconTabBarWBS" class="sapUiResponsiveContentPadding" select="onIconTabBarSelect">
                <items>
                    <IconTabFilter icon="sap-icon://hint" text="Information">
                        
                        <form:SimpleForm 
                            editable="false"
                            layout="ResponsiveGridLayout"
                            title="Chi tiết công việc"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                            columnsXL="2" columnsL="2" columnsM="1"
                            singleContainerFullSize="false">
                            <form:content>
                                
                                <core:Title text="Định danh" />
                                
                                <Label text="Tên công việc (Name)" design="Bold" />
                                <Text text="{wbs_name}" />

                                <Label text="Mã công việc (Code)" />
                                <Text text="{wbs_code}" />

                                <Label text="WBS ID" />
                                <Text text="{wbs_id}" />

                                <core:Title text="Tiến độ (Kế hoạch vs Thực tế)" />

                                <Label text="Ngày bắt đầu (Plan)" />
                                <Text text="{path: 'start_date', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <Label text="Ngày kết thúc (Plan)" />
                                <Text text="{path: 'end_date', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <Label text="Bắt đầu thực tế (Actual)" />
                                <Text text="{path: 'start_actual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <Label text="Kết thúc thực tế (Actual)" />
                                <Text text="{path: 'end_actual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <core:Title text="Chỉ số &amp; Trạng thái" />

                                <Label text="Quantity" />

<ObjectNumber
    number="{
        path: 'quantity',
        type: 'sap.ui.model.type.Float',
        formatOptions: {
            minFractionDigits: 0,
            maxFractionDigits: 0,
            groupingEnabled: true
        }
    }"
    unit="{unit_code}"
    state="None" />

                                <Label text="Trạng thái" />
                                <ObjectStatus 
                                    text="{status}" 
                                    state="{= ${status} === 'COMPLETED' ? 'Success' : 'Warning' }" 
                                    icon="{= ${status} === 'COMPLETED' ? 'sap-icon://accept' : 'sap-icon://pending' }" />

                            </form:content>
                        </form:SimpleForm>

                    </IconTabFilter>
                    
                    <IconTabFilter id="idDailyLogTab" key="dailyLogTab" icon="sap-icon://Chart-Tree-Map" text="Daily Log">
                        <!-- Fragment will be loaded programmatically when tab is selected -->
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>