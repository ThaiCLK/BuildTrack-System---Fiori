<mvc:View
    controllerName="z.bts.buildtrack.controller.WBSDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Page title="WBS Detail: {WbsName}" showNavButton="true" navButtonPress="onNavBack">
        <headerContent>
            <Button icon="sap-icon://dimension" text="Dashboard" type="Emphasized" press="onNavToDashboard" />
        </headerContent>
        <content>
            <IconTabBar id="idIconTabBarWBS" class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter icon="sap-icon://hint" text="Thông tin" key="infoTab">
                        
                        <form:SimpleForm 
                            editable="false"
                            layout="ResponsiveGridLayout"
                            title="Work Item Details"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                            columnsXL="2" columnsL="2" columnsM="1"
                            singleContainerFullSize="false">
                            <form:content>
                                
                                <core:Title text="Identification" />
                                
                                <Label text="WBS Name" design="Bold" />
                                <Text text="{WbsName}" />

                                <Label text="WBS Code" />
                                <Text text="{WbsCode}" />

                                <core:Title text="Schedule (Planned vs Actual)" />

                                <Label text="Planned Start" />
                                <Text text="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <Label text="Planned End" />
                                <Text text="{path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <Label text="Actual Start" />
                                <Text text="{path: 'StartActual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <Label text="Actual End" />
                                <Text text="{path: 'EndActual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                                <core:Title text="Metrics &amp; Status" />

                                <Label text="Quantity" />
                                <ObjectNumber
                                    number="{
                                        path: 'Quantity',
                                        type: 'sap.ui.model.type.Float',
                                        formatOptions: {
                                            minFractionDigits: 0,
                                            maxFractionDigits: 0,
                                            groupingEnabled: true
                                        }
                                    }"
                                    unit="{UnitCode}"
                                    state="None" />

                                <Label text="Status" />
                                <ObjectStatus 
                                    text="{path: 'Status', formatter: '.formatWbsStatusText'}"
                                    state="{path: 'Status', formatter: '.formatWbsStatusState'}"
                                    icon="{path: 'Status', formatter: '.formatWbsStatusIcon'}" />

                            </form:content>
                        </form:SimpleForm>

                        <!-- Location Info -->
                        <form:SimpleForm
                            editable="false"
                            layout="ResponsiveGridLayout"
                            title="📍 Work Location"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                            columnsXL="2" columnsL="2" columnsM="1"
                            singleContainerFullSize="false"
                            class="sapUiSmallMarginTop"
                            visible="{= !!${locationModel>/LocationName} }">
                            <form:content>
                                <core:Title text="Location" />

                                <Label text="Location Name" design="Bold" />
                                <Text text="{locationModel>/LocationName}" />

                                <Label text="Location Code" />
                                <Text text="{locationModel>/LocationCode}" />

                                <Label text="Location Type" />
                                <ObjectStatus
                                    text="{locationModel>/LocationType}"
                                    state="{= ${locationModel>/LocationType} === 'FLOOR' ? 'Information' : ${locationModel>/LocationType} === 'ZONE' ? 'Success' : ${locationModel>/LocationType} === 'SHAFT' ? 'Warning' : 'None' }"/>

                                <core:Title text="Position (m)" />

                                <Label text="Horizontal Range" />
                                <Text text="{locationModel>/PosStart} → {locationModel>/PosEnd} {locationModel>/UnitCode}" />

                                <Label text="Vertical Range" />
                                <Text text="{locationModel>/PosBot} → {locationModel>/PosTop} {locationModel>/UnitCode}" />
                            </form:content>
                        </form:SimpleForm>

                    </IconTabFilter>
                    
                    <IconTabFilter id="idDailyLogTab" key="dailyLogTab" icon="sap-icon://activity-assigned-to-goal" text="Nhật ký" visible="{path: 'ParentId', formatter: '.isChildNode'}">
                        <!-- Fragment được include trực tiếp — không cần lazy load -->
                        <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.DailyLog" type="XML"/>
                    </IconTabFilter>
                    <IconTabFilter id="idWorkSummaryTab" icon="sap-icon://manager-insight" text="Tổng hợp" key="workSummaryTab">
                         <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.WorkSummary" type="XML" />
                    </IconTabFilter>
                    <IconTabFilter id="idApprovalLogTab" icon="sap-icon://approvals" text="Nhật ký phê duyệt" key="approvalLogTab">
                         <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.ApprovalLog" type="XML" />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>