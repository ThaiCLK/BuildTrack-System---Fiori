<mvc:View
    controllerName="z.bts.buildtrack.controller.SiteDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="Site Detail: {SiteName}" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <IconTabBar id="idIconTabBar" class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter icon="sap-icon://hint" text="General Info">
                        <Text text="General information about the site..." />
                    </IconTabFilter>
                    
                    <IconTabFilter id="idSiteWbsTab" icon="sap-icon://Chart-Tree-Map" text="WBS &amp; Schedule">
                        <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.WBS" type="XML" />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>