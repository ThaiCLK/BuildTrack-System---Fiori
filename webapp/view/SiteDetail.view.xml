<mvc:View
    controllerName="z.bts.buildtrack.controller.SiteDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="Site Detail: {site_name}" showNavButton="true" navButtonPress="onNavBack">
        <content>


            <IconTabBar id="idIconTabBar" class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter icon="sap-icon://hint" text="Thông tin chung">
                        <Text text="Nội dung thông tin chung của Site..." />
                    </IconTabFilter>
                    
                    <IconTabFilter icon="sap-icon://Chart-Tree-Map" text="WBS &amp; Tiến độ">
                        <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.WBS" type="XML" />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>