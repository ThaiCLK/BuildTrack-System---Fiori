<mvc:View
    controllerName="z.bts.buildtrack551.controller.SiteDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="{parts: [{path: 'SiteName'}], formatter: '.formatSiteDetailTitle'}" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <IconTabBar id="idIconTabBar" class="sapUiResponsiveContentPadding" select=".onTabSelect">
                <items>
                    <IconTabFilter icon="sap-icon://hint" text="{i18n>siteInfoTab}">
                        <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.SiteGeneralInfo" type="XML" />
                    </IconTabFilter>
                    
                    <IconTabFilter id="idSiteWbsTab" icon="sap-icon://Chart-Tree-Map" text="{i18n>siteWbsTab}">
                        <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.WBS" type="XML" />
                    </IconTabFilter>

                    <IconTabFilter icon="sap-icon://complete" text="{i18n>sitePendingApprovalTab}" visible="{= ${userModel>/userId} !== 'LEARN-549' }">
                        <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.WBSPendingApproval" type="XML" />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>