<mvc:View
    controllerName="z.bts.buildtrack.controller.SiteDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="Site Detail: {SiteName}" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <IconTabBar id="idIconTabBar" class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter icon="sap-icon://hint" text="Thông tin">
                        <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.SiteGeneralInfo" type="XML" />
                    </IconTabFilter>
                    
                    <IconTabFilter id="idSiteWbsTab" icon="sap-icon://Chart-Tree-Map" text="WBS &amp; Tiến độ">
                        <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.WBS" type="XML" />
                    </IconTabFilter>

                    <IconTabFilter icon="sap-icon://complete" text="Chờ phê duyệt" visible="{= ${userModel>/userId} !== 'LEARN-549' }">
                        <core:Fragment fragmentName="z.bts.buildtrack.view.fragments.WBSPendingApproval" type="XML" />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>