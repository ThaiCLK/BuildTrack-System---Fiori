<mvc:View controllerName="z.bts.buildtrack551.controller.App"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Shell id="shell" appWidthLimited="false">
        <Page id="rootPage" enableScrolling="false" showHeader="true">
            <customHeader>
                <Bar class="dashboardHeader">
                    <contentLeft>
                        <HBox alignItems="Center">
                            <Button icon="sap-icon://home" text="{i18n>home}" type="Transparent" press=".onNavToDashboard" class="dashboardHeaderBtn"/>
                        </HBox>
                    </contentLeft>
                    <contentRight>
                        <Button icon="sap-icon://refresh" tooltip="{i18n>refresh}" type="Transparent" press=".onGlobalRefresh" class="dashboardHeaderBtn"/>
                        <MenuButton icon="sap-icon://world" tooltip="{i18n>language}" class="dashboardHeaderBtn">
                            <menu>
                                <Menu itemSelected=".onLanguageSelect">
                                    <items>
                                        <MenuItem key="en" text="{i18n>english}" icon="sap-icon://flag-2" />
                                        <MenuItem key="vi" text="{i18n>vietnamese}" icon="sap-icon://flag-2" />
                                    </items>
                                </Menu>
                            </menu>
                        </MenuButton>
                        <Button icon="sap-icon://discussion-2" tooltip="{i18n>assistantTitle}" type="Transparent" press=".onOpenAssistant" class="dashboardHeaderBtn"/>
                        <Button icon="sap-icon://customer" type="Transparent" press=".onPressProfile" class="dashboardHeaderBtn"/>
                    </contentRight>
                </Bar>
            </customHeader>
            <content>
                <App id="app"/>
            </content>
        </Page>
    </Shell>
</mvc:View>