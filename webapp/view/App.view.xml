<mvc:View controllerName="z.bts.buildtrack551.controller.App"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page enableScrolling="false">
        <customHeader>
            <Bar class="dashboardHeader">
                <contentLeft>
                    <HBox alignItems="Center">
                        <Button icon="sap-icon://home" text="Home" type="Transparent" press=".onNavToDashboard" class="dashboardHeaderBtn"/>
                    </HBox>
                </contentLeft>
                <contentRight>
                    <Button icon="sap-icon://discussion-2" text="Assistant" type="Transparent" press=".onOpenAssistant" class="dashboardHeaderBtn"/>
                    <Button icon="sap-icon://customer" type="Transparent" press=".onPressProfile" class="dashboardHeaderBtn"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <App id="app"/>
        </content>
    </Page>
</mvc:View>