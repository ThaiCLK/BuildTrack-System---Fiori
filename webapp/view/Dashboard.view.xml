<mvc:View
    controllerName="z.bts.buildtrack551.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizdata="sap.viz.ui5.data"
    xmlns:feeds="sap.viz.ui5.controls.common.feeds">

    <Page id="pageDashboard" showHeader="false" class="dashboardPage sapUiNoContentPadding">
        <content>
            <ScrollContainer height="100%" width="100%" vertical="true" horizontal="false" class="sapUiNoContentPadding">
            <l:VerticalLayout width="100%" class="dashboardContent sapUiNoContentPadding">

                <!-- ══════════════════════════════════════════════════════
                     TOP ROW: Project Overview (left) + Daily Operations (right)
                ══════════════════════════════════════════════════════ -->
                <HBox width="100%" class="dashboardTopRow">

                    <!-- LEFT COLUMN — Project Overview -->
                    <VBox class="dashboardColumn">
                        <Title id="secProject" text="{i18n>dashboardProjectOverview}" level="H4"
                            class="dashboardSectionTitle"/>

                        <HBox class="dashboardCardRow">
                            <Panel id="cardMyProjects" class="dashboardCard dashboardCardClickable"
                                   headerText="" expandable="false">
                                <layoutData><FlexItemData growFactor="0" baseSize="16rem"/></layoutData>
                                <HBox alignItems="Center" class="dashboardCardHeader">
                                    <core:Icon src="sap-icon://project-definition-triangle" class="dashboardCardIcon iconBlue"/>
                                    <VBox class="sapUiTinyMarginBegin">
                                        <Title text="{i18n>dashboardMyProjects}" level="H5"/>
                                    </VBox>
                                </HBox>
                                <HBox alignItems="Center" justifyContent="Start" class="dashboardCardBody">
                                    <VBox alignItems="Center">
                                        <Text text="{dashboard>/planningProjects}" class="dashboardBigNumber"/>
                                        <Text text="{i18n>dashboardPlanningProjects}" class="dashboardSubLabel"/>
                                    </VBox>
                                </HBox>
                            </Panel>

                            <Panel id="cardProjectSites" class="dashboardCard dashboardCardClickable"
                                   headerText="" expandable="false">
                                <layoutData><FlexItemData growFactor="0" baseSize="16rem"/></layoutData>
                                <HBox alignItems="Center" class="dashboardCardHeader">
                                    <core:Icon src="sap-icon://building" class="dashboardCardIcon iconGreen"/>
                                    <VBox class="sapUiTinyMarginBegin">
                                        <Title text="{i18n>dashboardProjectSites}" level="H5"/>
                                    </VBox>
                                </HBox>
                                <HBox alignItems="Center" justifyContent="Start" class="dashboardCardBody">
                                    <VBox alignItems="Center">
                                        <Text text="{dashboard>/planningSites}" class="dashboardBigNumber"/>
                                        <Text text="{i18n>dashboardPlanningSites}" class="dashboardSubLabel"/>
                                    </VBox>
                                </HBox>
                            </Panel>
                        </HBox>
                    </VBox>

                    <!-- RIGHT COLUMN — Daily Operations -->
                    <VBox class="dashboardColumn">
                        <Title id="secOps" text="{i18n>dashboardDailyOperations}" level="H4"
                            class="dashboardSectionTitle"/>

                        <HBox class="dashboardCardRow">
                            <Panel id="cardWeather" class="dashboardCard"
                                   headerText="" expandable="false">
                                <layoutData><FlexItemData growFactor="0" baseSize="30rem"/></layoutData>
                                <HBox alignItems="Center" class="dashboardCardHeader">
                                    <core:Icon src="sap-icon://weather-proofing" class="dashboardCardIcon iconOrange"/>
                                    <VBox class="sapUiTinyMarginBegin">
                                        <Title text="{i18n>dashboardWeatherToday}" level="H5"/>
                                    </VBox>
                                </HBox>
                                <HBox justifyContent="SpaceAround" alignItems="Center" class="dashboardCardBody">
                                    <VBox alignItems="Center">
                                        <Text text="{dashboard>/weatherTemp}" class="dashboardBigNumber"/>
                                        <Text text="{dashboard>/weatherCity}" class="dashboardSubLabel"/>
                                    </VBox>
                                    <VBox alignItems="Center">
                                        <core:Icon src="{dashboard>/weatherIcon}" size="2.2rem" color="#f39c12"/>
                                        <Text text="{dashboard>/weatherDesc}" class="dashboardSubLabel"/>
                                    </VBox>
                                </HBox>
                                <HBox class="dashboardCardFooterWeather" justifyContent="SpaceBetween">
                                    <Text text="💧 {dashboard>/weatherHumidity}%" class="dashboardWeatherDetail"/>
                                    <Text text="💨 {dashboard>/weatherWind} km/h" class="dashboardWeatherDetail"/>
                                </HBox>
                            </Panel>
                        </HBox>
                    </VBox>

                </HBox>



                <!-- ════════════════════════════════════════════════════════
                     SECTION 3 · ANALYTICS (SAP VizFrame Charts)
                ════════════════════════════════════════════════════════ -->
                <Title id="secAnalytics" text="{i18n>dashboardAnalytics}" level="H4"
                    class="dashboardSectionTitle"/>

                <!-- Filter Bar -->
                <OverflowToolbar class="dashboardFilterBar" style="border-radius:10px;background:#fff;box-shadow:0 2px 8px rgba(0,0,0,0.07);margin-bottom:0.75rem;padding:0.4rem 1rem;">
                    <core:Icon src="sap-icon://filter" style="color:#5899DA;margin-right:0.5rem;font-size:1rem;"/>
                    <Label text="{i18n>dashboardProjectLabel}" class="sapUiSmallMarginEnd" style="font-weight:600;color:#2c3e50;"/>
                    <ComboBox id="cbProject"
                        width="220px"
                        placeholder="{i18n>dashboardAllProjects}"
                        items="{dashboard>/projects}"
                        change=".onFilterChange"
                        selectionChange=".onFilterChange">
                        <core:Item key="{dashboard>ProjectId}" text="{dashboard>ProjectName}"/>
                    </ComboBox>
                    <ToolbarSpacer/>
                    <Button text="Reset" icon="sap-icon://refresh" press="onResetFilter" type="Transparent"/>
                </OverflowToolbar>

                <!-- Chart Grid Row 1: Donut + Stacked Bar -->
                <HBox class="dashboardChartRow" width="100%" renderType="Bare">

                    <!-- Card 1: WBS Status Donut -->
                    <Panel class="dashboardCard dashboardChartCard" headerText="" expandable="false">
                        <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                        <HBox alignItems="Center" class="dashboardCardHeader">
                            <core:Icon src="sap-icon://pie-chart" class="dashboardCardIcon iconBlue"/>
                            <VBox class="sapUiTinyMarginBegin">
                                <Title text="{i18n>dashboardWbsStatusDist}" level="H5"/>
                                <Text text="{i18n>dashboardWbsStatusDesc}" class="dashboardSubLabel"/>
                            </VBox>
                        </HBox>
                        <viz:VizFrame id="chartWbsStatus"
                            vizType="donut"
                            width="100%"
                            height="260px"
                            class="dashboardVizFrame">
                            <viz:dataset>
                                <vizdata:FlattenedDataset data="{dashboard>/wbsStatusChart}">
                                    <vizdata:dimensions>
                                        <vizdata:DimensionDefinition name="Status" value="{dashboard>status}"/>
                                    </vizdata:dimensions>
                                    <vizdata:measures>
                                        <vizdata:MeasureDefinition name="Count" value="{dashboard>count}"/>
                                    </vizdata:measures>
                                </vizdata:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <feeds:FeedItem uid="color" type="Dimension" values="Status"/>
                                <feeds:FeedItem uid="size" type="Measure" values="Count"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </Panel>

                    <!-- Card 2: WBS per Site Stacked Bar (wider) -->
                    <Panel class="dashboardCard dashboardChartCard" headerText="" expandable="false">
                        <layoutData><FlexItemData growFactor="2" baseSize="0%"/></layoutData>
                        <HBox alignItems="Center" class="dashboardCardHeader">
                            <core:Icon src="sap-icon://bar-chart" class="dashboardCardIcon iconGreen"/>
                            <VBox class="sapUiTinyMarginBegin">
                                <Title text="{i18n>dashboardWbsPerSite}" level="H5"/>
                                <Text text="{i18n>dashboardWbsPerSiteDesc}" class="dashboardSubLabel"/>
                            </VBox>
                        </HBox>
                        <viz:VizFrame id="chartWbsPerSite"
                            vizType="stacked_bar"
                            width="100%"
                            height="300px"
                            class="dashboardVizFrame">
                            <viz:dataset>
                                <vizdata:FlattenedDataset data="{dashboard>/wbsPerSiteChart}">
                                    <vizdata:dimensions>
                                        <vizdata:DimensionDefinition name="Site" value="{dashboard>site}"/>
                                        <vizdata:DimensionDefinition name="Status" value="{dashboard>status}"/>
                                    </vizdata:dimensions>
                                    <vizdata:measures>
                                        <vizdata:MeasureDefinition name="Count" value="{dashboard>count}"/>
                                    </vizdata:measures>
                                </vizdata:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <feeds:FeedItem uid="categoryAxis" type="Dimension" values="Site"/>
                                <feeds:FeedItem uid="color" type="Dimension" values="Status"/>
                                <feeds:FeedItem uid="valueAxis" type="Measure" values="Count"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </Panel>

                </HBox>

                <!-- Chart Grid Row 2: Line + Bar Progress -->
                <HBox class="dashboardChartRow" width="100%" renderType="Bare">

                    <!-- Card 3: Daily Output Line Chart (narrow) -->
                    <Panel class="dashboardCard dashboardChartCard" headerText="" expandable="false">
                        <layoutData><FlexItemData growFactor="2" baseSize="0%"/></layoutData>
                        <HBox alignItems="Center" class="dashboardCardHeader">
                            <core:Icon src="sap-icon://line-chart" class="dashboardCardIcon iconOrange"/>
                            <VBox class="sapUiTinyMarginBegin">
                                <Title text="{i18n>dashboardDailyOutput}" level="H5"/>
                                <Text text="{i18n>dashboardDailyOutputDesc}" class="dashboardSubLabel"/>
                            </VBox>
                        </HBox>
                        <viz:VizFrame id="chartDailyOutput"
                            vizType="line"
                            width="100%"
                            height="300px"
                            class="dashboardVizFrame">
                            <viz:dataset>
                                <vizdata:FlattenedDataset data="{dashboard>/dailyOutputChart}">
                                    <vizdata:dimensions>
                                        <vizdata:DimensionDefinition name="Date" value="{dashboard>date}"/>
                                    </vizdata:dimensions>
                                    <vizdata:measures>
                                        <vizdata:MeasureDefinition name="Quantity" value="{dashboard>quantity}"/>
                                    </vizdata:measures>
                                </vizdata:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date"/>
                                <feeds:FeedItem uid="valueAxis" type="Measure" values="Quantity"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </Panel>

                    <!-- Card 4: Top WBS Progress Bar Chart (wider) -->
                    <Panel class="dashboardCard dashboardChartCard" headerText="" expandable="false">
                        <layoutData><FlexItemData growFactor="2" baseSize="0%"/></layoutData>
                        <HBox alignItems="Center" justifyContent="SpaceBetween" class="dashboardCardHeader">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://activities" class="dashboardCardIcon iconTeal"/>
                                <VBox class="sapUiTinyMarginBegin">
                                    <Title text="{i18n>dashboardTopWbsCompletion}" level="H5"/>
                                    <Text text="{i18n>dashboardTopWbsCompletionDesc}" class="dashboardSubLabel"/>
                                </VBox>
                            </HBox>
                            <ComboBox id="cbWbsUnit"
                                      items="{dashboard>/wbsUnitList}"
                                      selectionChange=".onFilterChange"
                                      selectedKey="ALL"
                                      width="120px">
                                <core:Item key="{dashboard>Unit}" text="{dashboard>DisplayText}"/>
                            </ComboBox>
                        </HBox>
                        <viz:VizFrame id="chartWbsProgress"
                            vizType="stacked_bar"
                            width="100%"
                            height="300px"
                            class="dashboardVizFrame">
                            <viz:dataset>
                                <vizdata:FlattenedDataset data="{dashboard>/wbsProgressChart}">
                                    <vizdata:dimensions>
                                        <vizdata:DimensionDefinition name="WBS" value="{dashboard>wbsName}"/>
                                        <vizdata:DimensionDefinition name="Type" value="{dashboard>type}"/>
                                    </vizdata:dimensions>
                                    <vizdata:measures>
                                        <vizdata:MeasureDefinition name="Value" value="{dashboard>value}"/>
                                    </vizdata:measures>
                                </vizdata:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <feeds:FeedItem uid="categoryAxis" type="Dimension" values="WBS"/>
                                <feeds:FeedItem uid="color" type="Dimension" values="Type"/>
                                <feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </Panel>

                </HBox>

                <core:HTML content="&lt;div style='height:2rem'&gt;&lt;/div&gt;"/>

            </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
