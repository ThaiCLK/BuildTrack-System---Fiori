<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:html="http://www.w3.org/1999/xhtml">

    <VBox height="100%" fitContainer="true">
        <core:Fragment fragmentName="z.bts.buildtrack551.view.fragments.WBSStatusProgress" type="XML" />
        
        <VBox height="100%" fitContainer="true" class="approvalLogMasterPanel">
            <Toolbar design="Transparent">
                <Title text="{i18n>approvalLogTitle}" level="H5" />
                <ToolbarSpacer />
<!-- 
                <Button icon="sap-icon://sort" type="Transparent" /> -->
            </Toolbar>
            <ScrollContainer height="calc(100vh - 250px)" vertical="true" horizontal="false">
                <List id="idApprovalLogList" 
                    mode="None" 
                    items="{path: 'logListModel>/', sorter: {path: 'CreatedTimestamp', descending: true}}"
                    noDataText="{i18n>noApprovalLogsFound}">
                    <StandardListItem
                        title="{logListModel>Action} - {logListModel>WorkItemId}"
                        description="{logListModel>ActionBy}"
                        info="{path: 'logListModel>CreatedTimestamp', type: 'sap.ui.model.type.DateTime', formatOptions: {pattern: 'dd/MM/yyyy HH:mm:ss'}}"
                        infoState="{path: 'logListModel>Action', formatter: '.formatApprovalActionState'}"
                        icon="{path: 'logListModel>Action', formatter: '.formatApprovalActionIcon'}" />
                </List>
            </ScrollContainer>
        </VBox>
    </VBox>
</core:FragmentDefinition>
