<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:html="http://www.w3.org/1999/xhtml">

    <l:Splitter height="100%" width="100%">
        <!-- ── MASTER: List of logs (Versions) ─────────────────────────── -->
        <VBox height="100%" fitContainer="true" class="approvalLogMasterPanel">
            <layoutData><l:SplitterLayoutData size="380px" minSize="300px"/></layoutData>
            <Toolbar design="Transparent">
                <Title text="Lịch sử nghiệm thu" level="H5" />
                <ToolbarSpacer />
                <Button icon="sap-icon://sort" type="Transparent" />
            </Toolbar>
            <ScrollContainer height="calc(100vh - 250px)" vertical="true" horizontal="false">
                <List id="idApprovalLogList" mode="SingleSelectMaster" selectionChange="onLogSelectionChange">
                </List>
            </ScrollContainer>
        </VBox>

        <!-- ── DETAIL: A4 Document View ────────────────────────────────── -->
        <VBox height="100%" fitContainer="true" backgroundDesign="Translucent">
            
            <!-- Placeholder when no log is selected -->
            <VBox
                visible="{= !${approvalModel>/ui/isSelected} }"
                justifyContent="Center"
                alignItems="Center"
                height="100%">
                <core:Icon src="sap-icon://document" size="3rem" color="#bbb"/>
                <Text text="Select a log entry to view details" class="sapUiSmallMarginTop"/>
            </VBox>

            <!-- Actual Document Container -->
            <ScrollContainer height="calc(100vh - 215px)" width="100%" vertical="true" horizontal="false" class="approvalLogDetailArea" visible="{approvalModel>/ui/isSelected}">
                <VBox class="paperA4">
                    
                    <VBox alignItems="Center" class="sapUiMediumMarginTopBottom">
                        <Label text="CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM" design="Bold"/>
                        <Label text="Độc lập - Tự do - Hạnh phúc" design="Bold"/>
                        
                        <html:hr style="width: 150px; border-top: 1px solid black; margin-bottom: 20px;"/>
                        
                        <Title text="BIÊN BẢN NGHIỆM THU KHỐI LƯỢNG" titleStyle="H2" class="sapUiMediumMarginTop"/>
                        <Text text="Số: NT-{WbsCode}" />
                        <Text text="(Giai đoạn: {path: 'StartActual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}} - {path: 'EndActual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}})" class="sapUiTinyMarginBottom"/>
                    </VBox>

                    <f:SimpleForm editable="false" layout="ResponsiveGridLayout"
                        labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"
                        adjustLabelSpan="false" singleContainerFullSize="false">
                        <f:content>
                            <core:Title text="I. THÔNG TIN CHUNG" />
                            
                            <Label text="Dự án / Gói thầu" design="Bold"/>
                            <Text text="{projectModel>/ProjectName}" />
                            
                            <Label text="Hạng mục (WBS)" design="Bold"/>
                            <Text text="{WbsName} (Mã: {WbsCode})" />

                            <Label text="Phân khu" design="Bold"/>
                            <Text text="{projectModel>/SiteName}" />

                            <Label text="Vị trí" design="Bold"/>
                            <Text text="{locationModel>/LocationName}" />
                            
                            <Label text="Nhà thầu" design="Bold"/>
                            <Text text="Công ty Thầu Xây dựng (Mặc định)" />
                        </f:content>
                    </f:SimpleForm>

                    <VBox class="sapUiSmallMargin">
                        <Title text="II. NỘI DUNG NGHIỆM THU" titleStyle="H5" class="sapUiTinyMarginBottom"/>
                        
                        <Table inset="false" class="sapUiSizeCompact">
                            <columns>
                                <Column><Text text="Nội dung công việc" /></Column>
                                <Column width="5rem" hAlign="Center"><Text text="ĐVT" /></Column>
                                <Column width="6rem" hAlign="End"><Text text="Kế hoạch" /></Column>
                                <Column width="6rem" hAlign="End"><Text text="Thực tế" /></Column>
                                <Column width="6rem" hAlign="Center"><Text text="Đánh giá" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{WbsName}" />
                                        <Text text="{UnitCode}" />
                                        <ObjectNumber number="{Quantity}" />
                                        <ObjectNumber number="{TotalQuantityDone}" state="{= ${TotalQuantityDone} >= ${Quantity} ? 'Success' : 'Warning'}" />
                                        <ObjectStatus text="{approvalModel>/selectedLog/Action}" state="{path: 'approvalModel>/selectedLog/Action', formatter: '.formatApprovalActionState'}" icon="{path: 'approvalModel>/selectedLog/Action', formatter: '.formatApprovalActionIcon'}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <f:SimpleForm editable="false" layout="ResponsiveGridLayout">
                        <f:content>
                            <core:Title text="III. KẾT LUẬN" />
                            <Text text="Các bên đồng ý nghiệm thu khối lượng công việc nêu trên theo ghi nhận lúc {path: 'approvalModel>/selectedLog/ActionOn', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}." />
                        </f:content>
                    </f:SimpleForm>

                    <l:Grid defaultSpan="L4 M4 S12" class="sapUiLargeMarginTop sapUiMediumMarginBottom">
                        <l:content>
                            <VBox alignItems="Center">
                                <Label text="KỸ SƯ PHỤ TRÁCH" design="Bold"/>
                                <Label text="(Ký, ghi rõ họ tên)" />
                                <VBox height="90px" justifyContent="Center" alignItems="Center">
                                    <Text text="[Đã ký: {approvalModel>/selectedLog/ActionBy}]" class="signatureStamp" visible="{= ${approvalModel>/selectedLog/Action} === 'SUBMITTED' || ${approvalModel>/selectedLog/Action} === 'APPROVED' }" />
                                </VBox>                      
                            </VBox>

                            <VBox alignItems="Center">
                                <Label text="TƯ VẤN GIÁM SÁT" design="Bold"/>
                                <Label text="(Ký, ghi rõ họ tên)" />
                                <VBox height="90px" justifyContent="Center" alignItems="Center">
                                    <Text text="[Đã ký: Người Duyệt TVGS]" class="signatureStamp" visible="{= ${approvalModel>/selectedLog/Action} === 'APPROVED' }" />
                                </VBox>                      
                            </VBox>

                            <!-- ── INVESTOR REPRESENTATIVE (inline canvas e-sign) ── -->
                            <VBox alignItems="Center">
                                <Label text="ĐẠI DIỆN CHỦ ĐẦU TƯ" design="Bold"/>
                                <Label text="(Ký, ghi rõ họ tên)" />
                                <!-- Canvas: user draws directly here -->
                                <core:HTML id="investorSignatureCanvas" content="
                                    &lt;div style='display:flex; flex-direction:column; align-items:center; gap:4px;'&gt;
                                        &lt;canvas id='investorCanvas' width='180' height='80'
                                            style='border:1.5px dashed #3498db; border-radius:4px; background:#fafdf8;
                                                cursor:crosshair; touch-action:none; display:block;'&gt;
                                        &lt;/canvas&gt;
                                        &lt;div style='display:flex; gap:6px;'&gt;
                                            &lt;a href='javascript:void(0)' id='clearInvestorCanvas'
                                            style='font-size:0.7rem; color:#e74c3c; text-decoration:none;'&gt;✖ Xoá&lt;/a&gt;
                                        &lt;/div&gt;
                                    &lt;/div&gt;
                                " />
                            </VBox>
                        </l:content>
                    </l:Grid>

                </VBox>
            </ScrollContainer>
        </VBox>
    </l:Splitter>
</core:FragmentDefinition>
