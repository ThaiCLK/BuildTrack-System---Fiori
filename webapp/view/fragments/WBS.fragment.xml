<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:rowmodes="sap.ui.table.rowmodes">

    <!-- Toolbar WBS CRUD -->
    <OverflowToolbar style="Clear" class="sapUiSmallMarginBottom">
        <Title text="WBS &amp; Gantt Schedule" level="H4"/>
        <ToolbarSpacer/>
        <Button
            id="btnRunWbs"
            text="Run WBS"
            icon="sap-icon://play"
            type="Emphasized"
            press=".onRunWbs"
            tooltip="Set selected WBS to In Progress"/>
        <Button
            id="btnAddWbs"
            text="Create WBS"
            icon="sap-icon://add"
            type="Default"
            press=".onAddWbs"
            tooltip="Create root WBS, or child WBS if a row is selected"/>
        <Button
            id="btnEditWbs"
            text="Edit"
            icon="sap-icon://edit"
            type="Default"
            press=".onEditWbs"/>
        <Button
            id="btnDeleteWbs"
            text="Delete"
            icon="sap-icon://delete"
            type="Reject"
            press=".onDeleteWbs"/>
    </OverflowToolbar>

    <t:TreeTable id="wbsTreeTable"
        rows="{path: 'viewData>/WBS', parameters: {arrayNames: ['children'], numberOfExpandedLevels: 2}}"
        selectionMode="MultiToggle"
        cellClick=".onGanttTaskClick">

        <t:rowMode>
            <rowmodes:Fixed rowCount="18" rowContentHeight="32" />
        </t:rowMode>

        <t:columns>
            <t:Column width="15rem">
                <t:label><Label text="Work progress" design="Bold"/></t:label>
                <t:template>
                    <HBox alignItems="Center">
                        <core:Icon src="{= ${viewData>Type} === 'WBS' ? 'sap-icon://folder-blank' : 'sap-icon://activity-items'}"
                                   class="sapUiTinyMarginEnd" 
                                   color="{= ${viewData>Type} === 'WBS' ? '#346187' : '#e67e22'}"/>
                        <Text text="{viewData>WbsName}" wrapping="false" tooltip="{viewData>WbsName}"/>
                    </HBox>
                </t:template>
            </t:Column>

            <t:Column width="8rem" hAlign="Center">
                <t:label><Label text="Status"/></t:label>
                <t:template>
                    <ObjectStatus
                        text="{path: 'viewData>Status', formatter: '.formatWbsStatusText'}"
                        state="{path: 'viewData>Status', formatter: '.formatWbsStatusState'}"/>
                </t:template>
            </t:Column>

            <t:Column width="6rem" hAlign="Center">
                <t:label><Label text="Start"/></t:label>
                <t:template>
                    <Text text="{path: 'viewData>StartDate', formatter: '.formatDate'}"/>
                </t:template>
            </t:Column>

            <t:Column width="6rem" hAlign="Center">
                <t:label><Label text="End"/></t:label>
                <t:template>
                    <Text text="{path: 'viewData>EndDate', formatter: '.formatDate'}"/>
                </t:template>
            </t:Column>

            <t:Column width="{viewConfig>/totalWidth}" resizable="false">
                <t:label>
                    <VBox width="{viewConfig>/totalWidth}" renderType="Bare">
                        <HBox items="{path: 'viewConfig>/timeScale'}" renderType="Bare" height="25px">
                            <items>
                                <FlexBox width="{viewConfig>monthWidth}" 
                                         justifyContent="Center" alignItems="Center" 
                                         class="gantt-month-header gantt-no-shrink">
                                    <Text text="{viewConfig>monthLabel}"/>
                                </FlexBox>
                            </items>
                        </HBox>
                        
                        <HBox items="{path: 'viewConfig>/timeScale'}" renderType="Bare" height="20px">
                            <items>
                                <HBox items="{path: 'viewConfig>days'}" renderType="Bare" class="gantt-no-shrink">
                                    <items>
                                        <FlexBox width="{viewConfig>dayWidth}" 
                                                 justifyContent="Center" alignItems="Center"
                                                 class="gantt-day-border gantt-no-shrink">
                                            <Text text="{viewConfig>dayLabel}" 
                                                  visible="{= ${viewConfig>dayLabel} !== ''}"
                                                  wrapping="false"/>
                                        </FlexBox>
                                    </items>
                                </HBox>
                            </items>
                        </HBox>
                    </VBox>
                </t:label>

                <t:template>
                    <FlexBox width="{viewConfig>/totalWidth}" renderType="Bare" direction="Column" class="gantt-row-container">
                        
                        <FlexBox renderType="Bare" alignItems="Center" class="gantt-line-height"
                                 visible="{path: 'viewData>ParentId', formatter: '.isRootNode'}">
                            <FlexBox width="{path: 'viewData>StartDate', formatter: '.calcMargin'}" class="gantt-no-shrink" renderType="Bare" />
                            <FlexBox width="{parts: ['viewData>StartDate', 'viewData>EndDate'], formatter: '.calcWidth'}" 
                                     class="gantt-bar-root gantt-no-shrink" renderType="Bare" />
                        </FlexBox>

                        <VBox renderType="Bare" visible="{path: 'viewData>ParentId', formatter: '.isChildNode'}">
                            
                            <FlexBox renderType="Bare" alignItems="Center" class="gantt-line-height-half">
                                <FlexBox width="{path: 'viewData>StartDate', formatter: '.calcMargin'}" class="gantt-no-shrink" renderType="Bare" />
                                <FlexBox width="{parts: ['viewData>StartDate', 'viewData>EndDate'], formatter: '.calcWidth'}" 
                                         class="gantt-bar-plan gantt-no-shrink" renderType="Bare" />
                                         <Text 
                        text="{parts: ['viewData>Quantity', 'viewData>UnitCode'], formatter: '.formatWorkVolume'}"
                        visible="{= ${viewData>Quantity} !== null &amp;&amp; ${viewData>Quantity} !== undefined }"
                        class="sapUiTinyMarginBegin gantt-label-nc" />
                            </FlexBox>

                            <FlexBox renderType="Bare" alignItems="Center" class="gantt-line-height-half"
                                     visible="{= !!${viewData>StartActual} }">
                                <FlexBox width="{path: 'viewData>StartActual', formatter: '.calcMargin'}" class="gantt-no-shrink" renderType="Bare" />
                                <FlexBox width="{parts: ['viewData>StartActual', 'viewData>EndActual'], formatter: '.calcWidth'}" 
                                         class="gantt-bar-actual gantt-no-shrink" renderType="Bare">
                                </FlexBox>
                            </FlexBox>
                        </VBox>

                    </FlexBox>
                </t:template>
            </t:Column>
        </t:columns>
    </t:TreeTable>
</core:FragmentDefinition>