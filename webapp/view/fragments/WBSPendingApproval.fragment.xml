<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <VBox>
        <!-- Single Table for all Pending Approvals (Open and Close) -->
        <Table
            id="pendingApprovalTable"
            items="{viewData>/pendingWBS}"
            noDataText="{i18n>noPendingWbs}"
            mode="MultiSelect"
            sticky="HeaderToolbar,ColumnHeaders">
            <headerToolbar>
                <OverflowToolbar>
                    <Title text="{i18n>pendingApprovalItems}" level="H3"/>
                    <ToolbarSpacer/>
                    <Button
                        text="{i18n>approve}"
                        type="Accept"
                        icon="sap-icon://accept"
                        press=".onApproveWbs" />
                    <Button
                        text="{i18n>reject}"
                        type="Reject"
                        icon="sap-icon://decline"
                        press=".onRejectWbs" />
                </OverflowToolbar>
            </headerToolbar>
            <columns>
                <Column width="8rem">
                    <Text text="{i18n>wbsCode}" />
                </Column>
                <Column>
                    <Text text="{i18n>wbsName}" />
                </Column>
                <Column width="10rem" hAlign="Center">
                    <Text text="{i18n>status}" />
                </Column>
                <Column width="9rem" hAlign="End">
                    <Text text="{i18n>quantity}" />
                </Column>
            </columns>
            <items>
                <ColumnListItem vAlign="Middle">
                    <cells>
                        <Text text="{viewData>WbsCode}" />
                        <Text text="{viewData>WbsName}" />
                        
                        <ObjectStatus
                            text="{path: 'viewData>Status', formatter: '.formatWbsStatusText'}"
                            state="{path: 'viewData>Status', formatter: '.formatWbsStatusState'}"
                            icon="{path: 'viewData>Status', formatter: '.formatWbsStatusIcon'}"
                            inverted="true" />
                            
                        <ObjectNumber
                            number="{viewData>Quantity}"
                            unit="{viewData>UnitCode}"
                            state="None" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </VBox>
</core:FragmentDefinition>
