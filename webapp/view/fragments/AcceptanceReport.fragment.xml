<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout">
    <Dialog 
        showHeader="false"
        contentWidth="820px"
        verticalScrolling="true"
        class="transparentDialog">
        <content>
            <VBox class="paperA4Dialog">
                <!-- Header -->
                <VBox class="acceptanceHeader">
                    <Label text="CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM" class="signatureLabel" />
                    <Label text="Độc lập - Tự do - Hạnh phúc" class="signatureLabel" />
                    <VBox class="acceptanceHeaderLine" />
                    
                    <Title text="BIÊN BẢN NGHIỆM THU KHỐI LƯỢNG" class="acceptanceTitle sapUiMediumMarginTop" />
                    <Text text="{parts: [{path: 'i18n>reportNo'}, {path: 'WbsCode'}], formatter: '.formatReportNo'}" class="infoTableValue" />
                    <Text text="{parts: [{path: 'i18n>periodLabel'}, {path: 'StartActual'}, {path: 'EndActual'}], formatter: '.formatPeriod'}" 
                            visible="{= ${StartActual} !== null || ${EndActual} !== null }"
                            class="signatureSubLabel sapUiTinyMarginTop"/>
                    <Text text="{parts: [{path: 'i18n>periodLabel'}, {path: 'StartDate'}, {path: 'EndDate'}], formatter: '.formatPeriod'}" 
                            visible="{= ${StartActual} === null &amp;&amp; ${EndActual} === null }"
                            class="signatureSubLabel sapUiTinyMarginTop"/>
                </VBox>

                <!-- Section I: Thông tin chung -->
                <VBox class="sapUiMediumMarginTop">
                    <Label text="I. THÔNG TIN CHUNG" class="signatureLabel sapUiSmallMarginBottom" />
                    <VBox class="sapUiSmallMarginBegin">
                        <HBox class="infoTableRow" width="100%">
                            <Label text="Nhà thầu:" class="infoTableLabel" />
                            <Text text="Công ty Thành An 116" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow" width="100%">
                            <Label text="Dự án / Gói thầu:" class="infoTableLabel" />
                            <Text text="{projectModel>/ProjectName}" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow" width="100%">
                            <Label text="Hạng mục (Hạng mục):" class="infoTableLabel" />
                            <Text text="{WbsName} (Mã: {WbsCode})" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow" width="100%">
                            <Label text="Phân khu:" class="infoTableLabel" />
                            <Text text="{projectModel>/SiteName}" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow" width="100%">
                            <Label text="Vị trí:" class="infoTableLabel" />
                            <Text text="{locationModel>/LocationName}" class="infoTableValue" />
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Section II: Nội dung nghiệm thu -->
                <VBox class="sapUiMediumMarginTop">
                    <Label text="II. NỘI DUNG NGHIỆM THU" class="signatureLabel sapUiSmallMarginBottom" />
                    
                    <!-- Simulated Table for 1 row to guarantee rendering on all devices -->
                    <VBox class="acceptanceTableWrapper sapUiTinyMarginTop" width="100%">
                        <!-- Header Row -->
                        <HBox class="acceptanceTableHeader" width="100%" renderType="Bare">
                            <Text text="Nội dung công việc" class="tableHeaderCell colMain" />
                            <Text text="Kế hoạch" class="tableHeaderCell col15 cellEnd" />
                            <Text text="Thực tế" class="tableHeaderCell col15 cellEnd" />
                            <Text text="ĐVT" class="tableHeaderCell col10 cellCenter" />
                            <Text text="Đánh giá" class="tableHeaderCell col15 cellCenter" />
                        </HBox>
                        <!-- Data Row -->
                        <HBox class="acceptanceTableRow" width="100%" renderType="Bare">
                            <Text text="{WbsName}" class="tableDataCell colMain" />
                            <Text text="{path: 'Quantity', formatter: '.formatTotalQty'}" class="tableDataCell col15 cellEnd" />
                            <Text text="{path: 'workSummaryModel>/TotalQtyDone', formatter: '.formatTotalQty'}" class="tableDataCell col15 cellEnd" />
                            <Text text="{UnitCode}" class="tableDataCell col10 cellCenter" />
                            <VBox class="tableDataCell col15 cellCenter">
                                <ObjectStatus 
                                    text="{= ${viewData>/evaluationResult} === '1' ? 'Đạt' : (${viewData>/evaluationResult} === '2' ? 'Chưa Đạt' : '') }"
                                    state="{= ${viewData>/evaluationResult} === '1' ? 'Success' : (${viewData>/evaluationResult} === '2' ? 'Error' : 'None') }" />
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Section III: Kết luận -->
                <VBox class="sapUiMediumMarginTop">
                    <Label text="III. KẾT LUẬN" class="signatureLabel sapUiTinyMarginBottom" />
                    <Text text="Các bên đồng ý nghiệm thu khối lượng công việc nêu trên theo ghi nhận tại thời điểm hiện tại. Đạt yêu cầu kỹ thuật để triển khai công việc tiếp theo." 
                            class="acceptanceConclusion" />
                </VBox>

                <!-- Signatures -->
                <l:Grid defaultSpan="L4 M4 S12" class="sapUiLargeMarginTop sapUiMediumMarginBottom">
                    <l:content>
                        <!-- Kỹ sư phụ trách -->
                        <VBox alignItems="Center">
                            <Label text="KỸ SƯ PHỤ TRÁCH" class="signatureLabel" />
                            <Label text="(Ký, ghi rõ họ tên)" class="signatureSubLabel" />
                            <VBox class="signatureBox" justifyContent="Center" alignItems="Center">
                                <Image src="{viewData>/signStatus/level1/signatureUrl}" 
                                       height="60px" 
                                       visible="{= ${viewData>/signStatus/level1/signed} &amp;&amp; !!${viewData>/signStatus/level1/signatureUrl} }" 
                                       class="sapUiTinyMarginBottom" />
                                <Text text="{viewData>/signStatus/level1/text}" 
                                      class="{= ${viewData>/signStatus/level1/signed} ? 'signatureStamp signed' : 'signatureStamp' }" 
                                      visible="{viewData>/signStatus/level1/signed}" />
                                <Button text="Ký duyệt"
                                        type="Emphasized"
                                        press=".onApproveFromReport"
                                        visible="{viewData>/canApproveLevel1}" />
                            </VBox>                      
                        </VBox>

                        <!-- Tư vấn giám sát -->
                        <VBox alignItems="Center">
                            <Label text="TƯ VẤN GIÁM SÁT" class="signatureLabel" />
                            <Label text="(Ký, ghi rõ họ tên)" class="signatureSubLabel" />
                            <VBox class="signatureBox" justifyContent="Center" alignItems="Center">
                                <Image src="{viewData>/signStatus/level2/signatureUrl}" 
                                       height="60px" 
                                       visible="{= ${viewData>/signStatus/level2/signed} &amp;&amp; !!${viewData>/signStatus/level2/signatureUrl} }" 
                                       class="sapUiTinyMarginBottom" />
                                <Text text="{viewData>/signStatus/level2/text}" 
                                      class="{= ${viewData>/signStatus/level2/signed} ? 'signatureStamp signed' : 'signatureStamp' }" 
                                      visible="{viewData>/signStatus/level2/signed}" />
                                <Button text="Ký duyệt"
                                        type="Emphasized"
                                        press=".onApproveFromReport"
                                        visible="{viewData>/canApproveLevel2}" />
                            </VBox>                      
                        </VBox>

                        <!-- Đại diện chủ đầu tư -->
                        <VBox alignItems="Center">
                            <Label text="ĐẠI DIỆN CHỦ ĐẦU TƯ" class="signatureLabel" />
                            <Label text="(Ký, ghi rõ họ tên)" class="signatureSubLabel" />
                            <VBox class="signatureBox" justifyContent="Center" alignItems="Center">
                                <Image src="{viewData>/signStatus/level3/signatureUrl}" 
                                       height="60px" 
                                       visible="{= ${viewData>/signStatus/level3/signed} &amp;&amp; !!${viewData>/signStatus/level3/signatureUrl} }" 
                                       class="sapUiTinyMarginBottom" />
                                <Text text="{viewData>/signStatus/level3/text}" 
                                      class="{= ${viewData>/signStatus/level3/signed} ? 'signatureStamp signed' : 'signatureStamp' }" 
                                      visible="{viewData>/signStatus/level3/signed}" />
                                <Button text="Ký duyệt"
                                        type="Emphasized"
                                        press=".onApproveFromReport"
                                        visible="{viewData>/canApproveLevel3}" />
                            </VBox>                      
                        </VBox>
                    </l:content>
                </l:Grid>

                <!-- Footer Buttons placed inside the A4 Document -->
                <HBox justifyContent="End" class="paperA4DialogFooter">
                    <Button text="Gửi duyệt Đóng" type="Accept" class="sapUiSmallMarginEnd" press=".onSubmitForApproval" visible="{= (${userModel>/authLevel} === '0' || ${userModel>/authLevel} === 0) &amp;&amp; (${Status} === 'IN_PROGRESS' || ${Status} === 'CLOSE_REJECTED') }" />
                    <Button text="Từ chối" type="Reject" class="sapUiSmallMarginEnd" press=".onRejectFromReport" visible="{viewData>/canRejectFromReport}" />
                    <Button text="Đóng" press=".onCloseAcceptanceDialog" type="Default" />
                </HBox>
            </VBox>
        </content>
    </Dialog>
</core:FragmentDefinition>

