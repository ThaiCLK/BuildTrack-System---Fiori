<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout">
    <Dialog 
        title="{i18n>acceptanceReportTitle}" 
        contentWidth="750px"
        horizontalScrolling="false"
        verticalScrolling="false">
        <content>
            <VBox class="paperA4Dialog">
                <!-- Header -->
                <VBox class="acceptanceHeader">
                    <Label text="{i18n>vietnamOfficialName}" class="signatureLabel" />
                    <Label text="{i18n>vietnamMotto}" class="signatureLabel" />
                    <VBox class="acceptanceHeaderLine" />
                    
                    <Title text="{i18n>acceptanceReportHeader}" class="acceptanceTitle sapUiMediumMarginTop" />
                    <Text text="{parts: [{path: 'i18n>reportNo'}, {path: 'WbsCode'}], type: 'sap.ui.model.type.MessageFormat'}" class="infoTableValue" />
                    <Text text="{parts: [{path: 'i18n>periodLabel'}, {path: 'StartActual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}, {path: 'EndActual', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}], type: 'sap.ui.model.type.MessageFormat'}" 
                            visible="{= ${StartActual} !== null || ${EndActual} !== null }"
                            class="signatureSubLabel sapUiTinyMarginTop"/>
                    <Text text="{parts: [{path: 'i18n>periodLabel'}, {path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}, {path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}], type: 'sap.ui.model.type.MessageFormat'}" 
                            visible="{= ${StartActual} === null &amp;&amp; ${EndActual} === null }"
                            class="signatureSubLabel sapUiTinyMarginTop"/>
                </VBox>

                <!-- Section I: Thông tin chung -->
                <VBox class="sapUiMediumMarginTop">
                    <Label text="{i18n>sectionIGeneralInfo}" class="signatureLabel sapUiSmallMarginBottom" />
                    <VBox class="sapUiSmallMarginBegin">
                        <HBox class="infoTableRow">
                            <Label text="{i18n>projectPackageLabel}" class="infoTableLabel" />
                            <Text text="{projectModel>/ProjectName}" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow">
                            <Label text="{i18n>wbsItemLabel}" class="infoTableLabel" />
                            <Text text="{WbsName} (Mã: {WbsCode})" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow">
                            <Label text="{i18n>siteLabel}" class="infoTableLabel" />
                            <Text text="{projectModel>/SiteName}" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow">
                            <Label text="{i18n>locationLabel}" class="infoTableLabel" />
                            <Text text="{locationModel>/LocationName}" class="infoTableValue" />
                        </HBox>
                        <HBox class="infoTableRow">
                            <Label text="{i18n>contractorLabel}" class="infoTableLabel" />
                            <Text text="{i18n>defaultContractor}" class="infoTableValue" />
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Section II: Nội dung nghiệm thu -->
                <VBox class="sapUiMediumMarginTop">
                    <Label text="{i18n>sectionIIAcceptanceContent}" class="signatureLabel sapUiSmallMarginBottom" />
                    
                    <Table class="acceptanceTable" showNoData="false">
                        <columns>
                            <Column hAlign="Begin">
                                <Text text="{i18n>workContent}" />
                            </Column>
                            <Column width="10%" hAlign="Center">
                                <Text text="{i18n>unitShort}" />
                            </Column>
                            <Column width="15%" hAlign="End">
                                <Text text="{i18n>planned}" />
                            </Column>
                            <Column width="15%" hAlign="End">
                                <Text text="{i18n>actual}" />
                            </Column>
                            <Column width="15%" hAlign="Center">
                                <Text text="{i18n>evaluation}" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{WbsName}" />
                                    <Text text="{UnitCode}" />
                                    <Text text="{path: 'Quantity', formatter: '.formatTotalQty'}" />
                                    <Text text="{path: 'workSummaryModel>/TotalQtyDone', formatter: '.formatTotalQty'}" />
                                    <ObjectStatus 
                                        text="{= ${workSummaryModel>/TotalQtyDone} >= ${Quantity} ? ${i18n>achieved} : ${i18n>notAchieved} }"
                                        state="{= ${workSummaryModel>/TotalQtyDone} >= ${Quantity} ? 'Success' : 'Error' }" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>

                <!-- Section III: Kết luận -->
                <VBox class="sapUiMediumMarginTop">
                    <Label text="{i18n>sectionIIIConclusion}" class="signatureLabel sapUiTinyMarginBottom" />
                    <Text text="{i18n>acceptanceConclusionText}" 
                            class="acceptanceConclusion" />
                </VBox>

                <!-- Signatures -->
                <l:Grid defaultSpan="L4 M4 S12" class="sapUiLargeMarginTop sapUiMediumMarginBottom">
                    <l:content>
                        <!-- Kỹ sư phụ trách -->
                        <VBox alignItems="Center">
                            <Label text="{i18n>engineerRole}" class="signatureLabel" />
                            <Label text="{i18n>signAndFullName}" class="signatureSubLabel" />
                            <VBox minHeight="90px" justifyContent="Center" alignItems="Center">
                                <Image src="{viewData>/signStatus/level1/signatureUrl}" 
                                       height="60px" 
                                       visible="{= ${viewData>/signStatus/level1/signed} &amp;&amp; !!${viewData>/signStatus/level1/signatureUrl} }" 
                                       class="sapUiTinyMarginBottom" />
                                <Text text="{viewData>/signStatus/level1/text}" 
                                      class="{= ${viewData>/signStatus/level1/signed} ? 'signatureStamp signed' : 'signatureStamp' }" 
                                      visible="{viewData>/signStatus/level1/signed}" />
                                <Button text="{i18n>signApprove}"
                                        type="Emphasized"
                                        press=".onApproveFromReport"
                                        visible="{viewData>/canApproveLevel1}" />
                            </VBox>                      
                        </VBox>

                        <!-- Tư vấn giám sát -->
                        <VBox alignItems="Center">
                            <Label text="{i18n>supervisorRole}" class="signatureLabel" />
                            <Label text="{i18n>signAndFullName}" class="signatureSubLabel" />
                            <VBox minHeight="90px" justifyContent="Center" alignItems="Center">
                                <Image src="{viewData>/signStatus/level2/signatureUrl}" 
                                       height="60px" 
                                       visible="{= ${viewData>/signStatus/level2/signed} &amp;&amp; !!${viewData>/signStatus/level2/signatureUrl} }" 
                                       class="sapUiTinyMarginBottom" />
                                <Text text="{viewData>/signStatus/level2/text}" 
                                      class="{= ${viewData>/signStatus/level2/signed} ? 'signatureStamp signed' : 'signatureStamp' }" 
                                      visible="{viewData>/signStatus/level2/signed}" />
                                <Button text="{i18n>signApprove}"
                                        type="Emphasized"
                                        press=".onApproveFromReport"
                                        visible="{viewData>/canApproveLevel2}" />
                            </VBox>                      
                        </VBox>

                        <!-- Đại diện chủ đầu tư -->
                        <VBox alignItems="Center">
                            <Label text="{i18n>investorRole}" class="signatureLabel" />
                            <Label text="{i18n>signAndFullName}" class="signatureSubLabel" />
                            <VBox minHeight="90px" justifyContent="Center" alignItems="Center">
                                <Image src="{viewData>/signStatus/level3/signatureUrl}" 
                                       height="60px" 
                                       visible="{= ${viewData>/signStatus/level3/signed} &amp;&amp; !!${viewData>/signStatus/level3/signatureUrl} }" 
                                       class="sapUiTinyMarginBottom" />
                                <Text text="{viewData>/signStatus/level3/text}" 
                                      class="{= ${viewData>/signStatus/level3/signed} ? 'signatureStamp signed' : 'signatureStamp' }" 
                                      visible="{viewData>/signStatus/level3/signed}" />
                                <Button text="{i18n>signApprove}"
                                        type="Emphasized"
                                        press=".onApproveFromReport"
                                        visible="{viewData>/canApproveLevel3}" />
                            </VBox>                      
                        </VBox>
                    </l:content>
                </l:Grid>
            </VBox>
        </content>
        <buttons>
             <Button text="{i18n>submitForCloseApproval}" type="Accept" press=".onSubmitForApproval" visible="{= (${userModel>/authLevel} === '0' || ${userModel>/authLevel} === 0) &amp;&amp; (${Status} === 'IN_PROGRESS') }" />
             <Button text="{i18n>reject}" type="Reject" press=".onRejectFromReport" visible="{viewData>/canRejectFromReport}" />
             <Button text="{i18n>close}" press=".onCloseAcceptanceDialog" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
