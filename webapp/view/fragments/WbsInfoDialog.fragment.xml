<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    <Dialog title="{i18n>submitOpenApprovalTitle}" contentWidth="600px">
        <content>
            <VBox class="sapUiSmallMargin">
                <Panel headerText="{i18n>workItemInfo}" class="sapUiSmallMarginBottom">
                    <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" columnsL="1" columnsM="1">
                        <f:content>
                            <Label text="{i18n>workItemName}" design="Bold"/>
                            <Text text="{WbsName}" />
                            
                            <Label text="{i18n>workItemCode}" design="Bold"/>
                            <Text text="{WbsCode}" />

                            <Label text="{i18n>startDatePlanned}" design="Bold"/>
                            <Text text="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />

                            <Label text="{i18n>endDatePlanned}" design="Bold"/>
                            <Text text="{path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}" />
                        </f:content>
                    </f:SimpleForm>
                </Panel>
                
                <MessageStrip
                    text="{i18n>openStatusDescription}"
                    type="Information"
                    showIcon="true"
                    class="sapUiTinyMarginTop" />
            </VBox>
        </content>
        <beginButton>
            <Button text="{i18n>submitApproval}" type="Emphasized" press=".onDirectSubmitWS" />
        </beginButton>
        <endButton>
            <Button text="{i18n>cancelClose}" press=".onCloseWbsInfoDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
