<!--
    DailyLog.fragment.xml
    Daily Construction Log — Fragment used in the "Daily Log" tab of WBSDetail.view.xml
    Layout: Two-column Splitter
      ► Left  (380 px): List of log entries by date / WBS
      ► Right (rest)  : Detail form for the selected log entry
-->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- OUTER SPLITTER                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <l:Splitter height="100%" width="100%">

        <!-- ╔══════════════════════════════════════╗ -->
        <!-- ║  LEFT PANEL — Log entry list         ║ -->
        <!-- ╚══════════════════════════════════════╝ -->
        <VBox height="100%">
            <layoutData><l:SplitterLayoutData size="380px" minSize="300px"/></layoutData>

            <!-- Toolbar: title + add button -->
            <OverflowToolbar design="Solid">
                <Title text="Nhật ký thi công" level="H3"/>
                <ToolbarSpacer/>
                <!-- Excel actions grouped in a dropdown MenuButton -->
                <MenuButton
                    text="Excel"
                    icon="sap-icon://excel-attachment"
                    type="Default"
                    tooltip="Excel actions: Template / Import / Export"
                    menuPosition="BeginBottom">
                    <menu>
                        <Menu>
                            <items>
                                <MenuItem
                                    text="Download Template"
                                    icon="sap-icon://document-text"
                                    press=".onDownloadTemplate"/>
                                <MenuItem
                                    text="Import"
                                    icon="sap-icon://upload"
                                    press=".onImportExcel"/>
                                <MenuItem
                                    text="Export"
                                    icon="sap-icon://download"
                                    press=".onExportExcel"/>
                            </items>
                        </Menu>
                    </menu>
                </MenuButton>
                <Button
                    text="Delete Selected"
                    icon="sap-icon://delete"
                    type="Reject"
                    press=".onDeleteMultipleLogs"
                    visible="{= ${dailyLogModel>/ui/selectedLogsCount} > 0 }"/>
                <Button
                    text="Add Log"
                    icon="sap-icon://add"
                    type="Emphasized"
                    press=".onAddLog"/>
            </OverflowToolbar>

            <!-- Log list table bound to OData DailyLogSet -->
            <Table
                id="idDailyLogList"
                mode="MultiSelect"
                selectionChange=".onLogItemSelect"
                growing="true"
                growingThreshold="20"
                sticky="ColumnHeaders"
                noDataText="No log entries found. Click 'Add Log' to create one.">
                <columns>
                    <Column><Text text="Log Date"/></Column>
                    <Column hAlign="End" width="120px"><Text text="Qty Done"/></Column>
                </columns>
                <items>
                    <ColumnListItem type="Active" press=".onLogRowPress">
                        <cells>
                            <Text text="{
                                path: 'LogDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }"/>
                            <ObjectNumber
                                number="{path: 'QuantityDone', formatter: '.formatTotalQty'}"
                                unit="{UnitCode}"
                                state="None"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>

        <!-- ╔══════════════════════════════════════════════════════════╗ -->
        <!-- ║  RIGHT PANEL — Log detail                               ║ -->
        <!-- ╚══════════════════════════════════════════════════════════╝ -->
        <VBox id="idDailyLogDetailContainer" height="100%" backgroundDesign="Translucent">

            <!-- ── Top toolbar: title + edit/delete buttons ── -->
            <OverflowToolbar design="Solid">
                <Title text="Chi tiết nhật ký" level="H3"/>
                <ToolbarSpacer/>
                <Button
                    text="Edit"
                    icon="sap-icon://edit"
                    press=".onToggleEditMode"
                    visible="{dailyLogModel>/ui/isSelected}"
                    enabled="{= !${dailyLogModel>/ui/editMode} }"/>
                <Button
                    text="Delete"
                    icon="sap-icon://delete"
                    type="Reject"
                    press=".onDeleteLog"
                    visible="{dailyLogModel>/ui/isSelected}"
                    enabled="{= !${dailyLogModel>/ui/editMode} }"/>
            </OverflowToolbar>

            <!-- Placeholder when no log is selected -->
            <VBox
                visible="{= !${dailyLogModel>/ui/isSelected} }"
                justifyContent="Center"
                alignItems="Center"
                height="300px">
                <core:Icon src="sap-icon://document" size="3rem" color="#bbb"/>
                <Text text="Select a log entry to view details" class="sapUiSmallMarginTop"/>
            </VBox>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- SCROLL CONTAINER — full detail form                 -->
            <!-- ════════════════════════════════════════════════════ -->
            <ScrollContainer
                height="100%"
                vertical="true"
                visible="{dailyLogModel>/ui/isSelected}">

                <!-- ┌────────────────────────────────────────────────┐ -->
                <!-- │  BLOCK 1: REPORT HEADER                        │ -->
                <!-- └────────────────────────────────────────────────┘ -->
                <VBox class="sapUiSmallMargin">
                    <Panel headerText="General Information" class="sapUiTinyMarginBottom" width="auto" expandable="true" expanded="true">
                        <f:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            adjustLabelSpan="false"
                            columnsXL="2" columnsL="2" columnsM="1"
                            singleContainerFullSize="false">
                            <f:content>
                                <Label text="Report Date" required="true"/>
                                <DatePicker
                                    value="{
                                        path: 'dailyLogModel>/selectedLog/LogDate',
                                        type: 'sap.ui.model.type.Date',
                                        formatOptions: { pattern: 'dd/MM/yyyy' }
                                    }"
                                    editable="{dailyLogModel>/ui/editMode}"
                                    displayFormat="dd/MM/yyyy"
                                    valueFormat="dd/MM/yyyy"/>

                                <Label text="Quantity Done"/>
                                <HBox alignItems="Center">
                                    <Input
                                        value="{dailyLogModel>/selectedLog/QuantityDone}"
                                        editable="{dailyLogModel>/ui/editMode}"
                                        width="120px"
                                        type="Number"/>
                                    <Input
                                        value="{dailyLogModel>/selectedLog/UnitCode}"
                                        editable="{dailyLogModel>/ui/editMode}"
                                        width="80px"
                                        placeholder="Unit"
                                        class="sapUiTinyMarginBegin"/>
                                </HBox>
                            </f:content>
                        </f:SimpleForm>
                    </Panel>

                    <!-- ┌────────────────────────────────────────────────┐ -->
                    <!-- │  BLOCK 2: WEATHER                              │ -->
                    <!-- └────────────────────────────────────────────────┘ -->
                    <Panel headerText="Weather" class="sapUiTinyMarginBottom" width="auto" expandable="true" expanded="true">
                        <f:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            adjustLabelSpan="false"
                            columnsXL="2" columnsL="2" columnsM="1"
                            singleContainerFullSize="false">
                            <f:content>
                                <!-- Weather Morning -->
                                <Label text="Morning" required="true"/>
                                <Select
                                    selectedKey="{dailyLogModel>/selectedLog/WeatherAm}"
                                    enabled="{dailyLogModel>/ui/editMode}"
                                    width="100%">
                                    <items>
                                        <core:Item key="SUNNY"  text="Sunny "/>
                                        <core:Item key="CLOUDY" text="Cloudy "/>
                                        <core:Item key="RAINY"  text="Rainy "/>
                                        <core:Item key="STORM"  text="Storm "/>
                                    </items>
                                </Select>

                                <!-- Weather Afternoon -->
                                <Label text="Afternoon" required="true"/>
                                <Select
                                    selectedKey="{dailyLogModel>/selectedLog/WeatherPm}"
                                    enabled="{dailyLogModel>/ui/editMode}"
                                    width="100%">
                                    <items>
                                        <core:Item key="SUNNY"  text="Sunny "/>
                                        <core:Item key="CLOUDY" text="Cloudy "/>
                                        <core:Item key="RAINY"  text="Rainy "/>
                                        <core:Item key="STORM"  text="Storm "/>
                                    </items>
                                </Select>
                            </f:content>
                        </f:SimpleForm>
                    </Panel>

                    <!-- ┌────────────────────────────────────────────────┐ -->
                    <!-- │  BLOCK 3: RESOURCE USAGE (Vật tư / Thiết bị)  │ -->
                    <!-- └────────────────────────────────────────────────┘ -->
                    <Panel headerText="Resource Usage" class="sapUiTinyMarginBottom" width="auto" expandable="true" expanded="true">
                        <!-- Toolbar: resource table add button -->
                        <OverflowToolbar design="Transparent">
                            <ToolbarSpacer/>
                            <Button
                                text="Add Resource"
                                icon="sap-icon://add"
                                type="Ghost"
                                visible="{dailyLogModel>/ui/editMode}"
                                press=".onAddResourceUse"/>
                        </OverflowToolbar>

                        <!-- Resource usage table -->
                        <Table
                            id="idResourceUseTable"
                            items="{dailyLogModel>/resourceUseList}"
                            mode="{= ${dailyLogModel>/ui/editMode} ? 'Delete' : 'None' }"
                            delete=".onDeleteResourceUse"
                            width="100%"
                            noDataText="No resources added."
                            sticky="ColumnHeaders">
                            <columns>
                                <Column width="20%"><Text text="Code"/></Column>
                                <Column width="30%"><Text text="Resource"/></Column>
                                <Column width="15%"><Text text="Type"/></Column>
                                <Column width="20%" hAlign="Center"><Text text="Quantity"/></Column>
                                <Column width="15%"><Text text="Unit"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <!-- CELL 1: Resource Code (ResourceId) -->
                                        <Text text="{dailyLogModel>ResourceId}" wrapping="false"/>

                                        <!-- CELL 2: Resource name select / display -->
                                        <VBox>
                                            <Select
                                                selectedKey="{dailyLogModel>ResourceId}"
                                                enabled="{dailyLogModel>/ui/editMode}"
                                                visible="{dailyLogModel>/ui/editMode}"
                                                width="100%"
                                                items="{
                                                    path: '/ResourceSet',
                                                    templateShareable: false
                                                }"
                                                change=".onResourceIdChange">
                                                <core:ListItem
                                                    key="{ResourceId}"
                                                    text="{ResourceName}"/>
                                            </Select>
                                            <Text
                                                text="{dailyLogModel>ResourceName}"
                                                visible="{= !${dailyLogModel>/ui/editMode} }"
                                                wrapping="false"/>
                                        </VBox>

                                        <!-- CELL 3: Resource type (read-only) -->
                                        <Text text="{dailyLogModel>ResourceType}"/>

                                        <!-- CELL 4: Quantity -->
                                        <StepInput
                                            value="{dailyLogModel>Quantity}"
                                            min="0" max="99999" step="1"
                                            editable="{dailyLogModel>/ui/editMode}"
                                            width="100px"/>

                                        <!-- CELL 5: Unit (from resource master) -->
                                        <Text text="{dailyLogModel>UnitCode}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </Panel>

                    <!-- ┌────────────────────────────────────────────────┐ -->
                    <!-- │  BLOCK 4: NOTES                                │ -->
                    <!-- └────────────────────────────────────────────────┘ -->
                    <Panel headerText="Notes" width="auto" expandable="true" expanded="true">
                        <f:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="2" labelSpanL="2" labelSpanM="3" labelSpanS="12"
                            adjustLabelSpan="false"
                            columnsXL="1" columnsL="1" columnsM="1"
                            singleContainerFullSize="false">
                            <f:content>
                                <Label text="General Note"/>
                                <TextArea
                                    value="{dailyLogModel>/selectedLog/GeneralNote}"
                                    growing="true"
                                    growingMaxLines="10"
                                    rows="2"
                                    width="100%"
                                    editable="{dailyLogModel>/ui/editMode}"
                                    placeholder="Enter general notes for this work day..."/>

                                <Label text="Safety Note"/>
                                <TextArea
                                    value="{dailyLogModel>/selectedLog/SafeNote}"
                                    growing="true"
                                    growingMaxLines="6"
                                    rows="2"
                                    width="100%"
                                    editable="{dailyLogModel>/ui/editMode}"
                                    placeholder="Enter safety and environment notes..."/>

                                <Label text="Contractor Note"/>
                                <TextArea
                                    value="{dailyLogModel>/selectedLog/ContractorNote}"
                                    growing="true"
                                    growingMaxLines="6"
                                    rows="2"
                                    width="100%"
                                    editable="{dailyLogModel>/ui/editMode}"
                                    placeholder="Enter contractor representative notes..."/>
                            </f:content>
                        </f:SimpleForm>
                    </Panel>
                </VBox>
            </ScrollContainer><!-- end ScrollContainer -->

            <!-- ════════════════════════════════════════════════════ -->
            <!-- FOOTER TOOLBAR — actions (visible when isSelected)  -->
            <!-- ════════════════════════════════════════════════════ -->
            <OverflowToolbar
                design="Solid"
                visible="{= ${dailyLogModel>/ui/isSelected} }">
                <ToolbarSpacer/>
                <!-- Save Log -->
                <Button
                    text="Save"
                    icon="sap-icon://save"
                    type="Emphasized"
                    enabled="{dailyLogModel>/ui/editMode}"
                    press=".onSaveLog"/>
                <!-- Cancel: discard changes -->
                <Button
                    text="Cancel"
                    type="Transparent"
                    press=".onCancelEdit"/>
            </OverflowToolbar>

        </VBox><!-- end Right Panel -->

    </l:Splitter>

</core:FragmentDefinition>
