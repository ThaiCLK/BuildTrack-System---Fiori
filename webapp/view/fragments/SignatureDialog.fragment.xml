<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="signatureDialog"
        title="Chữ ký - Đại diện chủ đầu tư"
        contentWidth="520px"
        contentHeight="320px"
        resizable="false"
        draggable="true">

        <content>
            <VBox alignItems="Center" width="100%" class="sapUiSmallMarginTop">
                <Label text="Vẽ chữ ký của bạn trong ô bên dưới:" class="sapUiTinyMarginBottom" />
                <core:HTML id="signatureHtml" content="
                    &lt;div style='border:2px dashed #ccc; border-radius:6px; background:#fafafa; display:inline-block;'&gt;
                        &lt;canvas id='signatureCanvas' width='460' height='220'
                            style='display:block; cursor:crosshair; touch-action:none;'&gt;
                        &lt;/canvas&gt;
                    &lt;/div&gt;
                " />
            </VBox>
        </content>

        <beginButton>
            <Button text="Xoá" icon="sap-icon://clear-all" type="Transparent" press="onClearSignature" />
        </beginButton>

        <endButton>
            <Button text="Hủy" icon="sap-icon://cancel" type="Default" press="onCancelSignature" />
        </endButton>

        <customData>
            <core:CustomData key="confirmButton" value="ConfirmPlaceholder" />
        </customData>

        <buttons>
            <Button text="Ký nhận" icon="sap-icon://create" type="Emphasized" press="onConfirmSignature" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
