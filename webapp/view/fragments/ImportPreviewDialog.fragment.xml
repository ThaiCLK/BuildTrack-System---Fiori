<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Dialog
        id="importPreviewDialog"
        title="{i18n>importPreviewTitle}"
        contentWidth="800px"
        draggable="true"
        resizable="true">

        <content>
            <VBox class="sapUiSmallMargin">
                <!-- Summary bar -->
                <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                    <Label
                        text="{parts: [ {path: 'i18n>logsFoundInFile'}, {path: 'importPreviewModel>/logs/length'} ], formatter: '.formatImportPreviewLogCount'}"
                        design="Bold"/>
                    <Label
                        text="{i18n>tickLogsToImport}"
                        class="sapUiTinyMarginBegin"/>
                </HBox>

                <!-- Log preview table (multi-select) -->
                <Table
                    id="importPreviewTable"
                    mode="MultiSelect"
                    items="{importPreviewModel>/logs}"
                    growing="true"
                    growingThreshold="20"
                    noDataText="{i18n>noLogsFound}">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{i18n>logsToImport}" level="H5"/>
                            <ToolbarSpacer/>
                            <Button
                                text="{i18n>selectAll}"
                                type="Transparent"
                                press=".onImportPreviewSelectAll"/>
                            <Button
                                text="{i18n>deselectAll}"
                                type="Transparent"
                                press=".onImportPreviewDeselectAll"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="5rem">
                            <Text text="{i18n>logNum}"/>
                        </Column>
                        <Column width="8rem">
                            <Text text="{i18n>date}"/>
                        </Column>
                        <Column width="7rem" hAlign="End">
                            <Text text="{i18n>qtyDone}"/>
                        </Column>
                        <Column width="7rem">
                            <Text text="{i18n>weatherAM}"/>
                        </Column>
                        <Column width="7rem">
                            <Text text="{i18n>weatherPM}"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{importPreviewModel>log_num}"/>
                                <Text text="{
                                        path: 'importPreviewModel>log_date',
                                        formatter: '.formatImportDate'
                                    }"/>
                                <ObjectNumber
                                    number="{importPreviewModel>qty_done}"
                                    unit="{importPreviewModel>unit_code}"
                                    state="None"/>
                                <Text text="{path: 'importPreviewModel>weather_am', formatter: '.formatWeather'}"/>
                                <Text text="{path: 'importPreviewModel>weather_pm', formatter: '.formatWeather'}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>

        <beginButton>
            <Button
                text="{i18n>importSelected}"
                type="Emphasized"
                icon="sap-icon://upload"
                press=".onConfirmImport"/>
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                type="Default"
                press=".onCancelImport"/>
        </endButton>

    </Dialog>
</core:FragmentDefinition>
