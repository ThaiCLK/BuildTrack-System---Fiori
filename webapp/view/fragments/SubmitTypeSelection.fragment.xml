<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog title="Lựa chọn loại gửi duyệt" contentWidth="350px">
        <content>
            <VBox class="sapUiMediumMargin" alignItems="Center">
                <Text text="Bạn muốn gửi phê duyệt để MỞ hay ĐÓNG công việc này?" class="sapUiSmallMarginBottom" textAlign="Center" />
                <HBox width="100%" justifyContent="SpaceAround" class="sapUiMediumMarginTop">
                    <VBox alignItems="Center">
                        <Button 
                            text="MỞ (Opened)" 
                            type="Accept" 
                            icon="sap-icon://status-in-process" 
                            press=".onSelectOpenSubmission" 
                            width="140px"/>
                        <Text text="Tiến hành thi công" class="sapUiTinyMarginTop"/>
                    </VBox>
                    <VBox alignItems="Center">
                        <Button 
                            text="ĐÓNG (Closed)" 
                            type="Emphasized" 
                            icon="sap-icon://status-completed" 
                            press=".onSelectCloseSubmission" 
                            width="140px"/>
                        <Text text="Nghiệm thu hoàn tất" class="sapUiTinyMarginTop"/>
                    </VBox>
                </HBox>
            </VBox>
        </content>
        <beginButton>
            <Button text="Đóng" press=".onCloseSubmitTypeDialog" />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>
