<?xml version="1.0" encoding="UTF-8" ?>
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog title="{i18n>depAddDialogTitle}" contentWidth="500px">
        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Predecessor WBS Select -->
                <Label text="{i18n>depPredecessorWbs}" design="Bold" required="true" class="sapUiTinyMarginBottom" />
                <Select
                    id="selDepPredecessor"
                    width="100%"
                    selectedKey="{dependencyModel>/newDep/DepWbsId}"
                    items="{dependencyModel>/allWbs}"
                    class="sapUiSmallMarginBottom">
                    <core:Item key="{dependencyModel>WbsId}"
                               text="{dependencyModel>WbsName}" />
                </Select>

                <!-- Dep Type -->
                <Label text="{i18n>depTypeLabel}" design="Bold" required="true" class="sapUiTinyMarginBottom" />
                <Select
                    id="selDepType"
                    width="100%"
                    selectedKey="{dependencyModel>/newDep/DepType}"
                    class="sapUiSmallMarginBottom">
                    <core:Item key="FS" text="{i18n>depTypeFS}" />
                    <core:Item key="SS" text="{i18n>depTypeSS}" />
                    <core:Item key="FF" text="{i18n>depTypeFF}" />
                    <core:Item key="SF" text="{i18n>depTypeSF}" />
                </Select>

            </VBox>
        </content>
        <beginButton>
            <Button
                text="{i18n>depConfirmAdd}"
                type="Emphasized"
                press=".onConfirmAddDependency" />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                press=".onCancelAddDependency" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
