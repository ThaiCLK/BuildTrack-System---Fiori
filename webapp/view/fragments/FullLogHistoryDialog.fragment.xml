<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog title="{i18n>fullLogHistoryDialogTitle}" contentWidth="900px" contentHeight="600px" draggable="true" resizable="true">
        <VBox>
            <Toolbar>
                <SearchField placeholder="{i18n>fullLogHistorySearchPlaceholder}" width="100%" liveChange=".onSearchFullLogHistory"/>
            </Toolbar>

            <Table id="idFullLogHistoryTable" sticky="HeaderToolbar,ColumnHeaders" items="{workSummaryModel>/FullLogHistory}">
                <columns>
                    <Column width="15%">
                        <Text text="{i18n>fullLogHistoryDateCol}" design="Bold" />
                        <footer>
                            <Text text="{i18n>fullLogHistoryTotalLabel}" design="Bold" />
                        </footer>
                    </Column>

                    <Column width="20%" hAlign="End">
                        <Text text="{i18n>fullLogHistoryQtyCol}" design="Bold" />
                        <footer>
                            <ObjectNumber number="{workSummaryModel>/FullLogHistoryTotalQty}" unit="{workSummaryModel>/FullLogHistoryUnitCode}" />
                        </footer>
                    </Column>

                    <Column width="15%" hAlign="Center">
                        <Text text="{i18n>fullLogHistoryWeatherAmCol}" design="Bold" />
                        <footer>
                            <Text text="-" />
                        </footer>
                    </Column>

                    <Column width="15%" hAlign="Center">
                        <Text text="{i18n>fullLogHistoryWeatherPmCol}" design="Bold" />
                        <footer>
                            <Text text="-" />
                        </footer>
                    </Column>

                    <Column width="15%" hAlign="Center">
                        <Text text="{i18n>fullLogHistorySafeNoteCol}" design="Bold" />
                        <footer>
                            <Text text="-" />
                        </footer>
                    </Column>

                    <Column width="15%" hAlign="Center">
                        <Text text="{i18n>fullLogHistoryContractorNoteCol}" design="Bold" />
                        <footer>
                            <Text text="-" />
                        </footer>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{workSummaryModel>DateFormatted}" />
                            <ObjectNumber number="{workSummaryModel>Qty}" unit="{= ${workSummaryModel>Qty} === '-' ? '' : ${workSummaryModel>UnitCode} }" />
                            <Text text="{workSummaryModel>WeatherAmIcon}" tooltip="{workSummaryModel>WeatherAmTooltip}" class="sapUiLargeText" />
                            <Text text="{workSummaryModel>WeatherPmIcon}" tooltip="{workSummaryModel>WeatherPmTooltip}" class="sapUiLargeText" />
                            <VBox alignItems="Center">
                                <ObjectStatus icon="{workSummaryModel>SafeNoteIcon}" state="Warning" tooltip="{i18n>fullLogHistoryHasSafeNote}" visible="{= !!${workSummaryModel>SafeNoteIcon} }"/>
                                <Text text="-" visible="{= !${workSummaryModel>SafeNoteIcon} }"/>
                            </VBox>
                            <VBox alignItems="Center">
                                <ObjectStatus icon="{workSummaryModel>ContractorNoteIcon}" state="Warning" tooltip="{i18n>fullLogHistoryHasContractorNote}" visible="{= !!${workSummaryModel>ContractorNoteIcon} }"/>
                                <Text text="-" visible="{= !${workSummaryModel>ContractorNoteIcon} }"/>
                            </VBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>

        <beginButton>
            <Button text="{i18n>fullLogHistoryClose}" type="Reject" press=".onCloseFullLogHistory" />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>

