<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    
    <VBox class="sapUiSmallMargin">
        <ObjectHeader
            title="{SiteName}"
            icon="sap-icon://building"
            iconActive="false">
            <attributes>
                <ObjectAttribute text="{Address}" />
            </attributes>
        </ObjectHeader>

        <f:SimpleForm 
            editable="{viewData>/editMode}" 
            layout="ResponsiveGridLayout" 
            labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12" 
            adjustLabelSpan="false" 
            emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0" 
            columnsXL="1" columnsL="1" columnsM="1" 
            singleContainerFullSize="false" 
            class="sapUiSmallMarginTop">
            <f:toolbar>
                <Toolbar>
                    <Title text="{i18n>overviewInfo}" />
                    <ToolbarSpacer />
                    <Button id="btnEditSite" icon="sap-icon://edit" text="{i18n>edit}" press=".onEditSite" visible="{= !${viewData>/editMode} }" />
                    <Button id="btnSaveSite" icon="sap-icon://save" text="{i18n>save}" type="Emphasized" press=".onSaveSite" visible="{viewData>/editMode}" />
                    <Button id="btnCancelSite" icon="sap-icon://sys-cancel" text="{i18n>cancel}" press=".onCancelSite" visible="{viewData>/editMode}" />
                </Toolbar>
            </f:toolbar>
            <f:content>
                <Label text="{i18n>siteName}" />
                <VBox width="100%">
                    <Input id="inSiteName" value="{editModel>/SiteName}" visible="{viewData>/editMode}" />
                    <Text text="{SiteName}" visible="{= !${viewData>/editMode} }" />
                </VBox>

                <Label text="{i18n>siteCode}" />
                <VBox width="100%">
                    <Text id="inSiteCode" text="{SiteCode}" />
                </VBox>

                <Label text="{i18n>address}" />
                <VBox width="100%">
                    <Input id="inSiteAddress" value="{editModel>/Address}" visible="{viewData>/editMode}" />
                    <Text text="{Address}" visible="{= !${viewData>/editMode} }" />
                </VBox>

                <Label text="{i18n>status}" />
                <VBox width="100%">
                    <ObjectStatus 
                        class="sapUiNoMargin"
                        text="{path: 'Status', formatter: '.formatStatusText'}" 
                        state="{= ${Status} === 'READY' || ${Status} === 'COMPLETED' ? 'Success' : ${Status} === 'REJECTED' ? 'Error' : ${Status} === 'SUBMITTED' ? 'Information' : 'Warning' }" />
                </VBox>
            </f:content>
        </f:SimpleForm>
    </VBox>

</core:FragmentDefinition>
