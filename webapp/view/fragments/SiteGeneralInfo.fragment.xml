<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    
    <VBox class="sapUiSmallMargin">
        <ObjectHeader
            title="{SiteName}"
            intro="{SiteCode}"
            icon="sap-icon://building"
            iconActive="false">
            <statuses>
                <ObjectStatus
                    text="{Status}"
                    state="{= ${Status} === 'READY' || ${Status} === 'COMPLETED' ? 'Success' : ${Status} === 'REJECTED' ? 'Error' : ${Status} === 'SUBMITTED' ? 'Information' : 'Warning' }"/>
            </statuses>
            <attributes>
                <ObjectAttribute text="{Address}" icon="sap-icon://map-2" />
            </attributes>
        </ObjectHeader>

        <f:SimpleForm 
            editable="false" 
            layout="ResponsiveGridLayout" 
            title="Overview Information"
            labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12" 
            adjustLabelSpan="false" 
            emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0" 
            columnsXL="1" columnsL="1" columnsM="1" 
            singleContainerFullSize="false" 
            class="sapUiSmallMarginTop">
            <f:content>
                <Label text="Site Code" />
                <Text text="{SiteCode}" />

                <Label text="Address" />
                <Text text="{Address}" />

                <Label text="Status" />
                <ObjectStatus 
                    class="sapUiNoMargin"
                    text="{Status}" 
                    state="{= ${Status} === 'READY' || ${Status} === 'COMPLETED' ? 'Success' : ${Status} === 'REJECTED' ? 'Error' : ${Status} === 'SUBMITTED' ? 'Information' : 'Warning' }" />
            </f:content>
        </f:SimpleForm>
    </VBox>

</core:FragmentDefinition>
