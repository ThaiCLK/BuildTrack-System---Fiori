<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
>
    <ScrollContainer
        height="100%"
        width="100%"
        vertical="true"
        horizontal="true"
    >
        <VBox class="sapUiSmallMargin">
            <!-- ── Section I: Executive Summary (Header) ────────────────────────────────────────── -->
            <Panel headerText="Work Summary" class="sapUiSmallMarginBottom">
                <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="1" columnsM="1">
                    <f:content>
                        <Label text="Work Item Title" design="Bold"/>
                        <VBox>
                            <Text text="{WbsName}" design="Bold" style="font-size: 1.1rem;"/>
                            <Text text="Code: {WbsCode}" size="Tiny" color="Neutral" />
                        </VBox>
                        
                        <Label text="Project" design="Bold"/>
                        <Text text="{ProjectName}" />

                        <Label text="Completed (Cumulative)" design="Bold"/>
                                <ObjectNumber 
                                    number="{path: 'workSummaryModel>/TotalQtyDone', formatter: '.formatTotalQty'}" 
                                    unit="{UnitCode}" 
                                    state="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatQuantityState'}" />
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <!-- ── Section II: Progress Evaluation (Leaf Nodes Only) ──────────────────────────────── -->
            <Panel headerText="II. Progress Evaluation (Target vs Actual)" class="sapUiSmallMarginBottom" visible="{path: 'ParentId', formatter: '.isChildNode'}">
                <VBox width="100%">
                        <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom" width="100%">
                            <Label text="Completion Rate (Target: {Quantity} {UnitCode})" design="Bold"/>
                            <ObjectStatus 
                                text="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatPercentage'}" 
                                state="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatQuantityState'}" />
                        </HBox>
                        
                        <ProgressIndicator
                            percentValue="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatProgress'}"
                            displayValue="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatPercentage'}"
                            showValue="true"
                            state="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatQuantityState'}"
                            height="1.2rem"
                            width="100%"/>
                        
                    <l:Grid defaultSpan="L6 M6 S12" class="sapUiMediumMarginTop">
                        <l:content>
                            <VBox>
                                <Label text="Target (Planned)" class="sapUiTinyMarginBottom"/>
                                <ObjectNumber number="{Quantity}" unit="{UnitCode}" state="None" />
                            </VBox>
                            <VBox>
                                <Label text="Actual (Total Done)" class="sapUiTinyMarginBottom"/>
                                <ObjectNumber number="{path: 'workSummaryModel>/TotalQtyDone', formatter: '.formatTotalQty'}" unit="{UnitCode}" state="Success" />
                            </VBox>
                        </l:content>
                    </l:Grid>
                </VBox>
            </Panel>

            <!-- ── Section III: Children Summary Table (Parent Nodes Only) ────────────────────────── -->
            <Panel headerText="Detailed Progress Table (Sub-WBS)" class="sapUiSmallMarginBottom" visible="{path: 'ParentId', formatter: '.isParentNode'}">
                <Table items="{workSummaryModel>/Children}" sticky="HeaderToolbar,ColumnHeaders" width="100%">
                    <columns>
                        <Column width="4.5rem">
                            <Text text="WBS Code" />
                        </Column>
                        <Column minWidth="12rem">
                            <Text text="Work Item Name" />
                        </Column>
                        <Column hAlign="End" width="6.5rem">
                            <Text text="Planned" />
                        </Column>
                        <Column hAlign="End" width="6.5rem">
                            <Text text="Actual" />
                        </Column>
                        <Column width="8rem">
                            <Text text="Status" />
                        </Column>
                        <Column hAlign="Begin" width="18rem">
                            <Text text="Progress" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{workSummaryModel>WbsCode}" />
                                <Text text="{workSummaryModel>WbsName}" design="Bold" wrapping="true" />
                                <ObjectNumber number="{workSummaryModel>Quantity}" unit="{workSummaryModel>UnitCode}" />
                                <ObjectNumber 
                                    number="{workSummaryModel>TotalQtyDone}" 
                                    unit="{workSummaryModel>UnitCode}" 
                                    state="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatQuantityState'}" />
                                
                                <ObjectStatus 
                                    text="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusText'}" 
                                    state="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusState'}"
                                    icon="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusIcon'}" />

                                <HBox alignItems="Center" width="100%">
                                    <Text text="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatPercentage'}" 
                                          width="3.5rem" textAlign="End" class="sapUiTinyMarginEnd" />
                                    <ProgressIndicator
                                        percentValue="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatProgress'}"
                                        showValue="false"
                                        state="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatQuantityState'}"
                                        height="0.8rem"
                                        width="100%">
                                        <layoutData>
                                            <FlexItemData growFactor="1" />
                                        </layoutData>
                                    </ProgressIndicator>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </VBox>
    </ScrollContainer>
</core:FragmentDefinition>
