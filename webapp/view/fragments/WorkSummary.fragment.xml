<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:mc="sap.suite.ui.microchart"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data">
    <ScrollContainer height="100%" width="100%" vertical="true" horizontal="true">
        <VBox class="sapUiSmallMargin">

            <Panel class="sapUiSmallMarginBottom">
                <headerToolbar>
                    <Toolbar>
                        <Title text="{i18n>workSummaryTitle}" level="H4" />
                        <ToolbarSpacer />
                        <Button id="btnSubmitOpenWorkSummary" text="{i18n>submitOpen}" icon="sap-icon://sys-enter-2" type="Accept" press=".onPressSubmitOpenWorkSummary" visible="{= ${userModel>/authLevel} === '1' || ${userModel>/authLevel} === 1 }" />
                        <Button id="btnApproveOpenWorkSummary" text="{i18n>approveOpen}" icon="sap-icon://signature" type="Emphasized" press=".onApproveOpenWorkSummary" visible="{= (${userModel>/authLevel} === '2' || ${userModel>/authLevel} === 2 || ${userModel>/authLevel} === '3' || ${userModel>/authLevel} === 3) &amp;&amp; ${Status} === 'PENDING_OPEN' }" />
                        <Button id="btnRejectOpenWorkSummary" text="{i18n>rejectOpen}" icon="sap-icon://decline" type="Reject" press=".onRejectOpenWorkSummary" visible="{= (${userModel>/authLevel} === '2' || ${userModel>/authLevel} === 2 || ${userModel>/authLevel} === '3' || ${userModel>/authLevel} === 3) &amp;&amp; ${Status} === 'PENDING_OPEN' }" />
                        <Button id="btnSubmitCloseWorkSummary" text="{i18n>submitClose}" icon="sap-icon://sys-enter-2" type="Accept" press=".onPressSubmitCloseWorkSummary" visible="{= ${userModel>/authLevel} === '0' || ${userModel>/authLevel} === 0 }" />
                        <Button id="btnApproveCloseWorkSummary" text="{i18n>viewAcceptanceReport}" icon="sap-icon://display" type="Emphasized" press=".onPressSignAcceptanceReport" visible="{= ${Status} === 'CLOSED' || ${Status} === 'CLOSE_REJECTED' || (${Status} === 'PENDING_CLOSE' &amp;&amp; ${viewData>/isAcceptanceReportReady}) }" />
                    </Toolbar>
                </headerToolbar>
                <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="1" columnsM="1">
                    <f:content>
                        <Label text="{i18n>workItemTitle}" design="Bold"/>
                        <Text text="{WbsName}" />
                        <Label text="{i18n>wbsCode}" design="Bold"/>
                        <Text text="{WbsCode}" />
                        <Label text="{i18n>site}" design="Bold"/>
                        <Text text="{projectModel>/ProjectName} — {projectModel>/SiteName}" />
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <!-- Visible for ALL -->
            <Panel headerText="{i18n>wsTimeStatusPanel}" class="sapUiSmallMarginBottom">
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                    <Title text="{i18n>wsWbsStatusLabel}" level="H5"/>
                    <ObjectStatus text="{path: 'Status', formatter: '.formatWbsStatusText'}" state="{path: 'Status', formatter: '.formatWbsStatusState'}" inverted="true" />
                </HBox>
                <l:Grid defaultSpan="L6 M6 S12">
                    <l:content>
                        <VBox>
                            <Label text="{i18n>wsPlanTimeLabel}" design="Bold"/>
                            <Text text="{path: 'StartDate', formatter: '.formatPlanDateRange'}" class="sapUiTinyMarginTopBottom"/>
                            <ObjectStatus text="{path: 'StartDate', formatter: '.formatPlanDuration'}" state="None" />
                        </VBox>
                        <VBox>
                            <Label text="{i18n>wsActualTimeLabel}" design="Bold"/>
                            <Text text="{path: 'Status', formatter: '.formatActualDateRange'}" class="sapUiTinyMarginTopBottom"/>
                            <ObjectStatus text="{path: 'Status', formatter: '.formatActualDuration'}" state="{path: 'Status', formatter: '.formatActualDurationState'}" />
                        </VBox>
                    </l:content>
                </l:Grid>
            </Panel>
            <Panel headerText="{i18n>wsSummaryProgressPanel}" class="sapUiSmallMarginBottom" visible="{workSummaryModel>/IsParentNode}">
                <VBox width="100%" class="sapUiSmallMarginBottom sapUiSmallMarginTop">
                    <HBox justifyContent="SpaceBetween" width="100%">
                        <Label text="{i18n>wsActualProgressLabel}" design="Bold"/>
                        <Text text="{workSummaryModel>/ParentWeightedProgressStr}" />
                    </HBox>
                    <ProgressIndicator percentValue="{workSummaryModel>/ParentWeightedProgress}" showValue="false" state="{workSummaryModel>/ParentProgressState}" height="1.2rem" width="100%" class="sapUiTinyMarginBottom"/>

                    <HBox justifyContent="SpaceBetween" width="100%" class="sapUiMediumMarginTop">
                        <Label text="{i18n>wsPlannedProgressLabel}" design="Bold"/>
                        <Text text="{workSummaryModel>/ParentWeightedPlanProgressStr}" />
                    </HBox>
                    <ProgressIndicator percentValue="{workSummaryModel>/ParentWeightedPlanProgress}" showValue="false" state="Success" height="1.2rem" width="100%"/>

                    <HBox justifyContent="SpaceBetween" width="100%" class="sapUiMediumMarginTop">
                        <Label text="{i18n>wsTimeConsumptionLabel}" design="Bold"/>
                        <Text text="{workSummaryModel>/ParentTimeElapsedStr}" />
                    </HBox>
                    <ProgressIndicator percentValue="{workSummaryModel>/ParentTimeElapsedPercent}" showValue="false" state="{workSummaryModel>/ParentTimeState}" height="1.2rem" width="100%"/>
                </VBox>
            </Panel>

            <VBox visible="{workSummaryModel>/IsLeafNode}">
                <Panel headerText="{i18n>wsPerformancePanel}" class="sapUiSmallMarginBottom" visible="true">
                    <VBox width="100%" class="sapUiSmallMarginBottom sapUiSmallMarginTop">

                        <HBox justifyContent="SpaceBetween" width="100%">
                            <Label text="{i18n>wsActualProgressLabel}" design="Bold"/>
                            <Text text="{parts: [{path: 'Status'}, {path: 'workSummaryModel>/TotalQtyDone'}], formatter: '.formatQtyProgressDisplay'}" />
                        </HBox>
                        <ProgressIndicator percentValue="{path: 'workSummaryModel>/TotalQtyDone', formatter: '.formatQtyProgressPercent'}" displayValue="{path: 'workSummaryModel>/TotalQtyDone', formatter: '.formatQtyPercentageStr'}" showValue="true" state="{parts: [{path: 'Status'}, {path: 'workSummaryModel>/TotalQtyDone'}], formatter: '.formatQtyProgressState'}" height="1.2rem" width="100%" class="sapUiTinyMarginBottom"/>

                        <HBox justifyContent="SpaceBetween" width="100%" class="sapUiMediumMarginTop">
                            <Label text="{i18n>wsPlannedProgressLabel}" design="Bold"/>
                            <Text text="{path: 'Status', formatter: '.formatPlanQtyDisplay'}" />
                        </HBox>
                        <ProgressIndicator percentValue="{path: 'Status', formatter: '.formatPlanQtyPercent'}" displayValue="{path: 'Status', formatter: '.formatPlanQtyPercentStr'}" showValue="true" state="Success" height="1.2rem" width="100%" class="sapUiTinyMarginBottom"/>

                        <HBox justifyContent="SpaceBetween" width="100%" class="sapUiMediumMarginTop">
                            <Label text="{i18n>wsTimeConsumptionLabel}" design="Bold"/>
                            <Text text="{path: 'Status', formatter: '.formatTimeElapsedDisplay'}" />
                        </HBox>
                        <ProgressIndicator percentValue="{path: 'Status', formatter: '.formatTimeElapsedPercent'}" displayValue="{path: 'Status', formatter: '.formatTimeElapsedPercentStr'}" showValue="true" state="{path: 'Status', formatter: '.formatTimeElapsedState'}" height="1.2rem" width="100%"/>
                        <VBox class="sapUiLargeMarginTop">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" width="100%" class="sapUiTinyMarginBottom">
                                <Label text="{i18n>wsUpdateHistoryLabel}" design="Bold"/>
                                <Link text="{i18n>wsViewAllLabel}" press=".onPressViewFullLogHistory" />
                            </HBox>
                            <ScrollContainer horizontal="true" vertical="false" width="100%" class="sapUiSmallMarginTop sapUiSmallMarginBottom">
                                <Table showSeparators="Inner" width="100%" fixedLayout="false">
                                    <columns>
                                        <Column width="6rem" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                        <Column hAlign="Center" />
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <Label text="{i18n>date}" design="Bold" />
                                                <Text text="{workSummaryModel>/HistoryDates/0}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/1}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/2}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/3}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/4}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/5}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/6}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/7}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/8}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/9}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/10}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/11}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/12}" class="sapMTextBold" />
                                                <Text text="{workSummaryModel>/HistoryDates/13}" class="sapMTextBold" />
                                            </cells>
                                        </ColumnListItem>
                                        <ColumnListItem>
                                            <cells>
                                                <Label text="{i18n>dailyLogTab}" design="Bold" />
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/0} ? ${workSummaryModel>/HistoryLogIcons/0} : null }" color="{workSummaryModel>/HistoryLogColors/0}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/0} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/0}" visible="{= !${workSummaryModel>/HistoryLogIcons/0} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/1} ? ${workSummaryModel>/HistoryLogIcons/1} : null }" color="{workSummaryModel>/HistoryLogColors/1}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/1} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/1}" visible="{= !${workSummaryModel>/HistoryLogIcons/1} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/2} ? ${workSummaryModel>/HistoryLogIcons/2} : null }" color="{workSummaryModel>/HistoryLogColors/2}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/2} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/2}" visible="{= !${workSummaryModel>/HistoryLogIcons/2} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/3} ? ${workSummaryModel>/HistoryLogIcons/3} : null }" color="{workSummaryModel>/HistoryLogColors/3}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/3} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/3}" visible="{= !${workSummaryModel>/HistoryLogIcons/3} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/4} ? ${workSummaryModel>/HistoryLogIcons/4} : null }" color="{workSummaryModel>/HistoryLogColors/4}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/4} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/4}" visible="{= !${workSummaryModel>/HistoryLogIcons/4} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/5} ? ${workSummaryModel>/HistoryLogIcons/5} : null }" color="{workSummaryModel>/HistoryLogColors/5}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/5} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/5}" visible="{= !${workSummaryModel>/HistoryLogIcons/5} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/6} ? ${workSummaryModel>/HistoryLogIcons/6} : null }" color="{workSummaryModel>/HistoryLogColors/6}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/6} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/6}" visible="{= !${workSummaryModel>/HistoryLogIcons/6} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/7} ? ${workSummaryModel>/HistoryLogIcons/7} : null }" color="{workSummaryModel>/HistoryLogColors/7}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/7} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/7}" visible="{= !${workSummaryModel>/HistoryLogIcons/7} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/8} ? ${workSummaryModel>/HistoryLogIcons/8} : null }" color="{workSummaryModel>/HistoryLogColors/8}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/8} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/8}" visible="{= !${workSummaryModel>/HistoryLogIcons/8} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/9} ? ${workSummaryModel>/HistoryLogIcons/9} : null }" color="{workSummaryModel>/HistoryLogColors/9}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/9} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/9}" visible="{= !${workSummaryModel>/HistoryLogIcons/9} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/10} ? ${workSummaryModel>/HistoryLogIcons/10} : null }" color="{workSummaryModel>/HistoryLogColors/10}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/10} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/10}" visible="{= !${workSummaryModel>/HistoryLogIcons/10} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/11} ? ${workSummaryModel>/HistoryLogIcons/11} : null }" color="{workSummaryModel>/HistoryLogColors/11}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/11} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/11}" visible="{= !${workSummaryModel>/HistoryLogIcons/11} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/12} ? ${workSummaryModel>/HistoryLogIcons/12} : null }" color="{workSummaryModel>/HistoryLogColors/12}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/12} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/12}" visible="{= !${workSummaryModel>/HistoryLogIcons/12} }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{= ${workSummaryModel>/HistoryLogIcons/13} ? ${workSummaryModel>/HistoryLogIcons/13} : null }" color="{workSummaryModel>/HistoryLogColors/13}" size="1.2rem" visible="{= !!${workSummaryModel>/HistoryLogIcons/13} }"/>
                                                    <Text text="{workSummaryModel>/HistoryLogTexts/13}" visible="{= !${workSummaryModel>/HistoryLogIcons/13} }"/>
                                                </VBox>
                                            </cells>
                                        </ColumnListItem>
                                        <ColumnListItem>
                                            <cells>
                                                <Label text="{i18n>quantity}" design="Bold" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/0}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/1}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/2}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/3}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/4}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/5}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/6}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/7}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/8}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/9}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/10}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/11}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/12}" />
                                                <ObjectStatus text="{workSummaryModel>/HistoryQtys/13}" />
                                            </cells>
                                        </ColumnListItem>
                                        <ColumnListItem>
                                            <cells>
                                                <Label text="{i18n>weather}" design="Bold" />
                                                <Text text="{workSummaryModel>/HistoryWeathers/0}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/1}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/2}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/3}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/4}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/5}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/6}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/7}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/8}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/9}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/10}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/11}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/12}" class="sapUiMediumText"/>
                                                <Text text="{workSummaryModel>/HistoryWeathers/13}" class="sapUiMediumText"/>
                                            </cells>
                                        </ColumnListItem>
                                        <ColumnListItem>
                                            <cells>
                                                <Label text="{i18n>wsNotesScLabel}" design="Bold" />
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/0}" color="{workSummaryModel>/HistoryNoteColors/0}" visible="{= ${workSummaryModel>/HistoryNoteIcons/0} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/0}" visible="{= ${workSummaryModel>/HistoryNoteIcons/0} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/1}" color="{workSummaryModel>/HistoryNoteColors/1}" visible="{= ${workSummaryModel>/HistoryNoteIcons/1} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/1}" visible="{= ${workSummaryModel>/HistoryNoteIcons/1} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/2}" color="{workSummaryModel>/HistoryNoteColors/2}" visible="{= ${workSummaryModel>/HistoryNoteIcons/2} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/2}" visible="{= ${workSummaryModel>/HistoryNoteIcons/2} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/3}" color="{workSummaryModel>/HistoryNoteColors/3}" visible="{= ${workSummaryModel>/HistoryNoteIcons/3} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/3}" visible="{= ${workSummaryModel>/HistoryNoteIcons/3} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/4}" color="{workSummaryModel>/HistoryNoteColors/4}" visible="{= ${workSummaryModel>/HistoryNoteIcons/4} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/4}" visible="{= ${workSummaryModel>/HistoryNoteIcons/4} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/5}" color="{workSummaryModel>/HistoryNoteColors/5}" visible="{= ${workSummaryModel>/HistoryNoteIcons/5} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/5}" visible="{= ${workSummaryModel>/HistoryNoteIcons/5} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/6}" color="{workSummaryModel>/HistoryNoteColors/6}" visible="{= ${workSummaryModel>/HistoryNoteIcons/6} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/6}" visible="{= ${workSummaryModel>/HistoryNoteIcons/6} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/7}" color="{workSummaryModel>/HistoryNoteColors/7}" visible="{= ${workSummaryModel>/HistoryNoteIcons/7} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/7}" visible="{= ${workSummaryModel>/HistoryNoteIcons/7} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/8}" color="{workSummaryModel>/HistoryNoteColors/8}" visible="{= ${workSummaryModel>/HistoryNoteIcons/8} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/8}" visible="{= ${workSummaryModel>/HistoryNoteIcons/8} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/9}" color="{workSummaryModel>/HistoryNoteColors/9}" visible="{= ${workSummaryModel>/HistoryNoteIcons/9} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/9}" visible="{= ${workSummaryModel>/HistoryNoteIcons/9} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/10}" color="{workSummaryModel>/HistoryNoteColors/10}" visible="{= ${workSummaryModel>/HistoryNoteIcons/10} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/10}" visible="{= ${workSummaryModel>/HistoryNoteIcons/10} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/11}" color="{workSummaryModel>/HistoryNoteColors/11}" visible="{= ${workSummaryModel>/HistoryNoteIcons/11} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/11}" visible="{= ${workSummaryModel>/HistoryNoteIcons/11} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/12}" color="{workSummaryModel>/HistoryNoteColors/12}" visible="{= ${workSummaryModel>/HistoryNoteIcons/12} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/12}" visible="{= ${workSummaryModel>/HistoryNoteIcons/12} === '' }"/>
                                                </VBox>
                                                <VBox alignItems="Center">
                                                    <core:Icon src="{workSummaryModel>/HistoryNoteIcons/13}" color="{workSummaryModel>/HistoryNoteColors/13}" visible="{= ${workSummaryModel>/HistoryNoteIcons/13} !== '' }"/>
                                                    <Text text="{workSummaryModel>/HistoryNoteTexts/13}" visible="{= ${workSummaryModel>/HistoryNoteIcons/13} === '' }"/>
                                                </VBox>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </ScrollContainer>
                        </VBox>
                    </VBox>
                </Panel>
                <Panel headerText="{i18n>wsProductivityForecastPanel}" class="sapUiSmallMarginBottom" visible="true">
                    <VBox visible="{workSummaryModel>/IsLeafNode}" class="sapUiSmallMarginTop">
                        <viz:VizFrame
                            id="chartWbsBurnDown"
                            vizType="line"
                            height="300px"
                            width="100%">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{workSummaryModel>/BurnDownData}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="Ngày" value="{workSummaryModel>Date}"/>
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Kế hoạch" value="{workSummaryModel>Planned}"/>
                                        <viz.data:MeasureDefinition name="Thực tế" value="{workSummaryModel>Actual}"/>
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Kế hoạch,Thực tế"/>
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Ngày"/>
                            </viz:feeds>
                        </viz:VizFrame>
                        <viz:Popover id="popoverWbsBurnDown"/>
                    </VBox>
                    <l:Grid defaultSpan="L3 M6 S12" class="sapUiSmallMarginTopBottom">
                        <l:content>
                            <VBox>
                                <Label text="{i18n>wsAverageProductivityLabel}" design="Bold"/>
                                <Text class="sapUiTinyMarginTop" text="{
                                    parts: [
                                        {path: 'Status'},
                                        {path: 'workSummaryModel>/TotalQtyDone'}
                                    ],
                                    formatter: '.formatAverageProductivity'
                                }"/>
                            </VBox>
                            <VBox>
                                <Label text="{i18n>wsScheduleVarianceLabel}" design="Bold"/>
                                <ObjectStatus text="{
                                    parts: [
                                        {path: 'Status'},
                                        {path: 'workSummaryModel>/TotalQtyDone'}
                                    ],
                                    formatter: '.formatScheduleVarianceText'
                                }" state="{
                                    parts: [
                                        {path: 'Status'},
                                        {path: 'workSummaryModel>/TotalQtyDone'}
                                    ],
                                    formatter: '.formatScheduleVarianceState'
                                }" icon="{
                                    parts: [
                                        {path: 'Status'},
                                        {path: 'workSummaryModel>/TotalQtyDone'}
                                    ],
                                    formatter: '.formatScheduleVarianceIcon'
                                }" class="sapUiTinyMarginTop"/>
                            </VBox>
                            <VBox>
                                <Label text="{i18n>wsForecastDateLabel}" design="Bold"/>
                                <Text text="{
                                    parts: [
                                        {path: 'Status'},
                                        {path: 'workSummaryModel>/TotalQtyDone'}
                                    ],
                                    formatter: '.formatForecastDateText'
                                }" class="sapUiTinyMarginTop"/>
                            </VBox>
                            <VBox>
                                <Label text="{i18n>wsRiskAssessmentLabel}" design="Bold"/>
                                <ObjectStatus text="{
                                    parts: [
                                        {path: 'Status'},
                                        {path: 'workSummaryModel>/TotalQtyDone'}
                                    ],
                                    formatter: '.formatRiskAssessmentText'
                                }" state="{
                                    parts: [
                                        {path: 'Status'},
                                        {path: 'workSummaryModel>/TotalQtyDone'}
                                    ],
                                    formatter: '.formatRiskAssessmentState'
                                }" class="sapUiTinyMarginTop"/>
                            </VBox>
                        </l:content>
                    </l:Grid>
                </Panel>
                <Panel headerText="{i18n>wsWeatherRiskPanel}" class="sapUiSmallMarginBottom" visible="true">
                    <l:Grid defaultSpan="L6 M6 S12" class="sapUiSmallMarginTopBottom">
                        <l:content>

                            <VBox class="sapUiTinyMarginBottom sapUiLargeMarginEnd">
                                <Label text="{i18n>wsWeatherStatsTitle}" design="Bold" class="sapUiMediumMarginBottom"/>
                                <HBox class="sapUiTinyMarginBottom">
                                    <Text text="{i18n>wsCloudyLabel}" width="7rem" />
                                    <Text text="{workSummaryModel>/WeatherStats/CloudyText}" class="sapMTextBold" />
                                </HBox>
                                <HBox class="sapUiTinyMarginBottom">
                                    <Text text="{i18n>wsSunnyLabel}" width="7rem" />
                                    <Text text="{workSummaryModel>/WeatherStats/SunnyText}" class="sapMTextBold" />
                                </HBox>
                                <HBox class="sapUiTinyMarginBottom">
                                    <Text text="{i18n>wsRainyLabel}" width="7rem" />
                                    <Text text="{workSummaryModel>/WeatherStats/RainyText}" class="sapMTextBold" />
                                </HBox>
                                <HBox>
                                    <Text text="{i18n>wsStormyLabel}" width="7rem" />
                                    <Text text="{workSummaryModel>/WeatherStats/StormyText}" class="sapMTextBold" />
                                </HBox>
                            </VBox>
                            <VBox class="sapUiTinyMarginBottom">
                                <Label text="{i18n>wsRiskAlertLabel}" design="Bold" class="sapUiMediumMarginBottom"/>

                                <HBox alignItems="Start" class="sapUiSmallMarginBottom">
                                    <core:Icon src="{workSummaryModel>/RiskStats/SafeIcon}" color="{workSummaryModel>/RiskStats/SafeState}" class="sapUiTinyMarginEnd sapUiTinyMarginTop" size="1.2rem"/>
                                    <VBox>
                                        <Text text="{workSummaryModel>/RiskStats/SafeText}" class="sapMTextBold" />
                                        <Text text="{workSummaryModel>/RiskStats/SafeLevel}" />
                                    </VBox>
                                </HBox>
                                <HBox alignItems="Start">
                                    <core:Icon src="{workSummaryModel>/RiskStats/ContractorIcon}" color="{workSummaryModel>/RiskStats/ContractorState}" class="sapUiTinyMarginEnd sapUiTinyMarginTop" size="1.2rem"/>
                                    <VBox>
                                        <Text text="{workSummaryModel>/RiskStats/ContractorText}" class="sapMTextBold" />
                                        <Text text="{workSummaryModel>/RiskStats/ContractorLevel}" />
                                    </VBox>
                                </HBox>
                            </VBox>
                        </l:content>
                    </l:Grid>
                </Panel>

                <Panel headerText="{i18n>wsResourceForecastPanel}" class="sapUiSmallMarginBottom" visible="true">
                    <VBox class="sapUiSmallMargin">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="{i18n>wsResourceForecastLabel}" design="Bold"/>
                            <Text text=" ({workSummaryModel>/RemainingQtyText})" class="sapUiTinyMarginBegin"/>
                        </HBox>
                        <Table showSeparators="Inner" noDataText="{i18n>wsResourceForecastNoData}" items="{workSummaryModel>/ResourceForecasting}">
                            <columns>
                                <Column width="30%">
                                    <Text text="{i18n>wsResourceNameCol}" class="sapMTextBold" />
                                </Column>
                                <Column hAlign="Center">
                                    <Text text="{i18n>wsResourceTypeCol}" class="sapMTextBold" />
                                </Column>
                                <Column hAlign="End">
                                    <Text text="{i18n>wsResourceUsedCol}" class="sapMTextBold" />
                                </Column>
                                <Column hAlign="Center">
                                    <Text text="{i18n>wsResourceNormCol}" class="sapMTextBold" tooltip="{i18n>wsResourceNormTooltip}"/>
                                </Column>
                                <Column hAlign="End">
                                    <Text text="{i18n>wsResourceEtcCol}" class="sapMTextBold" tooltip="{i18n>wsResourceEtcTooltip}"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <ObjectIdentifier title="{workSummaryModel>ResourceName}" text="{workSummaryModel>ResourceId}" />
                                        <ObjectStatus text="{= ${workSummaryModel>ResourceType} === 'MATERIAL' ? ${i18n>resourceTypeMaterial} : (${workSummaryModel>ResourceType} === 'EQUIPMENT' ? ${i18n>resourceTypeEquipment} : (${workSummaryModel>ResourceType} === 'LABOR' ? ${i18n>resourceTypeLabor} : ${workSummaryModel>ResourceType})) }" state="{= ${workSummaryModel>ResourceType} === 'MATERIAL' ? 'Indication05' : (${workSummaryModel>ResourceType} === 'EQUIPMENT' ? 'Indication08' : (${workSummaryModel>ResourceType} === 'LABOR' ? 'Indication06' : 'None')) }" icon="{= ${workSummaryModel>ResourceType} === 'MATERIAL' ? 'sap-icon://product' : (${workSummaryModel>ResourceType} === 'EQUIPMENT' ? 'sap-icon://shipping-status' : (${workSummaryModel>ResourceType} === 'LABOR' ? 'sap-icon://employee' : 'sap-icon://question-mark')) }"/>
                                        <Text text="{workSummaryModel>UsedQuantityFormatted} {workSummaryModel>UnitCode}" />
                                        <ObjectStatus text="{workSummaryModel>NormText}" state="None" />
                                        <ObjectNumber number="{workSummaryModel>EtcQuantity}" unit="{workSummaryModel>UnitCode}" state="{workSummaryModel>EtcState}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </Panel>
            </VBox>

            <Panel headerText="{i18n>subWbsProgressTable}" class="sapUiSmallMarginBottom" visible="{workSummaryModel>/IsParentNode}">
                <Table items="{path: 'workSummaryModel>/Children', templateShareable: false}" sticky="HeaderToolbar,ColumnHeaders" width="100%">
                    <columns>
                        <Column>
                            <Text text="{i18n>wsSubWbsCodeCol}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>wsSubWbsActualProgressCol}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>wsSubWbsPlanProgressCol}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>wsSubWbsTimeCol}" />
                        </Column>
                        <Column hAlign="Begin">
                            <Text text="{i18n>wsSubWbsWeightCol}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>wsSubWbsAssessmentCol}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>status}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" press=".onPressChildWbs">
                            <cells>
                                <Text text="{workSummaryModel>WbsCode}" wrapping="true" />

                                <Text text="{workSummaryModel>QuantityProgressStr}" />

                                <Text text="{workSummaryModel>PlanProgressStr}" />

                                <Text text="{workSummaryModel>TimeProgressStr}" />

                                <Text text="{workSummaryModel>ContributionStr}" />

                                <ObjectStatus text="{workSummaryModel>AssessmentText}" state="{workSummaryModel>AssessmentState}" class="statusBadgeNoWrap" />

                                <ObjectStatus text="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusText'}" state="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusState'}" icon="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusIcon'}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </VBox>
    </ScrollContainer>
</core:FragmentDefinition>
