<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
>
    <ScrollContainer
        height="100%"
        width="100%"
        vertical="true"
        horizontal="true"
    >
        <VBox class="sapUiSmallMargin">
            <!-- ── Section I: Executive Summary (Header) ────────────────────────────────────────── -->
            <Panel class="sapUiSmallMarginBottom">
                <headerToolbar>
                    <Toolbar>
                        <Title text="{i18n>workSummaryTitle}" level="H4" />
                        <ToolbarSpacer />
                        <!-- Mở WBS -->
                        <Button
                            id="btnSubmitOpenWorkSummary"
                            text="{i18n>submitOpen}"
                            icon="sap-icon://sys-enter-2"
                            type="Accept"
                            press=".onPressSubmitOpenWorkSummary"
                            visible="{= ${userModel>/authLevel} === '0' || ${userModel>/authLevel} === 0 }"
                        />
                        <Button
                            id="btnApproveOpenWorkSummary"
                            text="{i18n>approveOpen}"
                            icon="sap-icon://signature"
                            type="Emphasized"
                            press=".onApproveOpenWorkSummary"
                            visible="{= (${userModel>/authLevel} !== '0' &amp;&amp; ${userModel>/authLevel} !== 0) &amp;&amp; ${Status} === 'PENDING_OPEN' }"
                        />
                        <Button
                            id="btnRejectOpenWorkSummary"
                            text="{i18n>rejectOpen}"
                            icon="sap-icon://decline"
                            type="Reject"
                            press=".onRejectOpenWorkSummary"
                            visible="{= (${userModel>/authLevel} !== '0' &amp;&amp; ${userModel>/authLevel} !== 0) &amp;&amp; ${Status} === 'PENDING_OPEN' }"
                        />
                        <!-- Đóng WBS -->
                        <Button
                            id="btnSubmitCloseWorkSummary"
                            text="{i18n>submitClose}"
                            icon="sap-icon://sys-enter-2"
                            type="Accept"
                            press=".onPressSubmitCloseWorkSummary"
                            visible="{= ${userModel>/authLevel} === '0' || ${userModel>/authLevel} === 0 }"
                        />
                        <Button
                            id="btnApproveCloseWorkSummary"
                            text="{i18n>viewAcceptanceReport}"
                            icon="sap-icon://display"
                            type="Emphasized"
                            press=".onPressSignAcceptanceReport"
                            visible="{= ${Status} === 'PENDING_CLOSE' || ${Status} === 'CLOSED' }"
                        />
                    </Toolbar>
                </headerToolbar>
                <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="1" columnsM="1">
                    <f:content>
                        <Label text="{i18n>workItemTitle}" design="Bold"/>
                        <VBox>
                            <Text text="{WbsName}" class="sapUiTinyMarginBottom" />
                            <Text text="{i18n>wbsCode}: {WbsCode}" />
                        </VBox>
                        
                        <Label text="{i18n>site}" design="Bold"/>
                        <Text text="{ProjectName}" />

                        <Label text="{i18n>completedCumulative}" design="Bold"/>
                                <VBox>
                                    <ObjectNumber 
                                        number="{
                                            path: 'workSummaryModel>/TotalQtyDone',
                                            type: 'sap.ui.model.type.Float',
                                            formatOptions: {
                                                maxFractionDigits: 0,
                                                groupingEnabled: true
                                            }
                                        }" 
                                        unit="{UnitCode}" 
                                        state="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatQuantityState'}" />
                                    <!-- Chú thích: chỉ hiện khi là WBS cha -->
                                    <Text
                                        text="{i18n>parentWbsAggregateNote}"
                                        visible="{path: 'ParentId', formatter: '.isParentNode'}"
                                        class="sapUiTinyMarginTop"
                                        wrapping="true"
                                        />
                                </VBox>
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <!-- ── Section II: Progress Evaluation (Leaf Nodes Only) ──────────────────────────────── -->
            <Panel headerText="{i18n>progressEvaluation}" class="sapUiSmallMarginBottom" visible="{path: 'ParentId', formatter: '.isChildNode'}">
                <VBox width="100%">
                        <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom" width="100%">
                            <Label text="{parts: ['Quantity', 'UnitCode'], formatter: '.formatCompletionRateTitle'}" design="Bold"/>
                            <ObjectStatus 
                                text="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatPercentage'}" 
                                state="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatQuantityState'}" />
                        </HBox>
                        
                        <ProgressIndicator
                            percentValue="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatProgress'}"
                            displayValue="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatPercentage'}"
                            showValue="true"
                            state="{parts: ['workSummaryModel>/TotalQtyDone', 'Quantity'], formatter: '.formatQuantityState'}"
                            height="1.2rem"
                            width="100%"/>
                        
                    <l:Grid defaultSpan="L6 M6 S12" class="sapUiMediumMarginTop">
                        <l:content>
                            <VBox>
                                <Label text="{i18n>targetPlanned}" class="sapUiTinyMarginBottom"/>
                                <ObjectNumber number="{path: 'Quantity', formatter: '.formatTotalQty'}" unit="{UnitCode}" state="None" />
                            </VBox>
                            <VBox>
                                <Label text="{i18n>actualTotalDone}" class="sapUiTinyMarginBottom"/>
                                <ObjectNumber number="{path: 'workSummaryModel>/TotalQtyDone', formatter: '.formatTotalQty'}" unit="{UnitCode}" state="Success" />
                            </VBox>
                        </l:content>
                    </l:Grid>
                </VBox>
            </Panel>

            <!-- ── Section III: Children Summary Table (Parent Nodes Only) ────────────────────────── -->
            <Panel headerText="{i18n>subWbsProgressTable}" class="sapUiSmallMarginBottom" visible="{path: 'ParentId', formatter: '.isParentNode'}">
                <Table items="{path: 'workSummaryModel>/Children', templateShareable: false}" sticky="HeaderToolbar,ColumnHeaders" width="100%">
                    <columns>
                        <Column width="4.5rem">
                            <Text text="{i18n>wbsCode}" />
                        </Column>
                        <Column width="12rem">
                            <Text text="{i18n>itemName}" />
                        </Column>
                        <Column hAlign="End" width="6.5rem">
                            <Text text="{i18n>targetPlanned}" />
                        </Column>
                        <Column hAlign="End" width="6.5rem">
                            <Text text="{i18n>actualTotalDone}" />
                        </Column>
                        <Column width="8rem">
                            <Text text="{i18n>status}" />
                        </Column>
                        <Column hAlign="Begin" width="18rem">
                            <Text text="{i18n>workProgress}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{workSummaryModel>WbsCode}" />
                                <Text text="{workSummaryModel>WbsName}" wrapping="true" />
                                <ObjectNumber 
                                    number="{
                                        path: 'workSummaryModel>Quantity',
                                        type: 'sap.ui.model.type.Float',
                                        formatOptions: {
                                            maxFractionDigits: 0,
                                            groupingEnabled: true
                                        }
                                    }" 
                                    unit="{workSummaryModel>UnitCode}" />
                                <ObjectNumber 
                                    number="{
                                        path: 'workSummaryModel>TotalQtyDone',
                                        type: 'sap.ui.model.type.Float',
                                        formatOptions: {
                                            maxFractionDigits: 0,
                                            groupingEnabled: true
                                        }
                                    }" 
                                    unit="{workSummaryModel>UnitCode}" 
                                    state="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatQuantityState'}" />
                                
                                <ObjectStatus 
                                    text="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusText'}" 
                                    state="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusState'}"
                                    icon="{path: 'workSummaryModel>Status', formatter: '.formatWbsStatusIcon'}" />

                                <HBox alignItems="Center" width="100%">
                                    <Text text="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatPercentage'}" 
                                          width="3.5rem" textAlign="End" class="sapUiTinyMarginEnd" />
                                    <ProgressIndicator
                                        percentValue="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatProgress'}"
                                        showValue="false"
                                        state="{parts: ['workSummaryModel>TotalQtyDone', 'workSummaryModel>Quantity'], formatter: '.formatQuantityState'}"
                                        height="0.8rem"
                                        width="100%">
                                        <layoutData>
                                            <FlexItemData growFactor="1" />
                                        </layoutData>
                                    </ProgressIndicator>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </VBox>
    </ScrollContainer>
</core:FragmentDefinition>
