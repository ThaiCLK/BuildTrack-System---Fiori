<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">

    <ScrollContainer height="100%" width="100%" vertical="true" horizontal="false">
        <VBox class="sapUiSmallMargin">
            
            <!-- ── Report Header ────────────────────────────────────────────── -->
            <Panel class="sapUiSmallMarginBottom customReportHeader">
                <headerToolbar>
                    <Toolbar height="3rem">
                        <Title text="Work Summary" level="H4" />
                        <ToolbarSpacer />
                        <Button text="Submit for Approval" type="Emphasized" icon="sap-icon://paper-plane"/>
                    </Toolbar>
                </headerToolbar>
                <content>
                    <HBox wrap="Wrap" alignItems="Center">
                        <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                            <Label text="Work Item Title" design="Bold"/>
                            <Title text="{WbsName}" level="H5" />
                            <Text text="Code: {WbsCode}" class="sapUiTinyMarginTop"/>
                        </VBox>
                        
                        <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                            <Label text="Project" design="Bold"/>
                            <Text text="Vinhomes Smart City - Zone S1"/>
                        </VBox>

                        <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                            <Label text="Status" design="Bold"/>
                            <ObjectStatus 
                                text="{= ${workSummaryModel>/TotalQuantityDone} >= ${Quantity} ? 'COMPLETED' : 'IN PROGRESS' }" 
                                state="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity'], formatter: '.formatQuantityState'}" 
                                inverted="true" 
                                icon="{= ${workSummaryModel>/TotalQuantityDone} >= ${Quantity} ? 'sap-icon://accept' : 'sap-icon://edit' }" />
                        </VBox>
                    </HBox>
                </content>
            </Panel>

            <!-- ── Section I: Executed Volume ─────────────────────────── -->
            <Panel headerText="I. Executed Volume" class="sapUiSmallMarginBottom">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout" 
                    labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12" 
                    columnsXL="2" columnsL="2" columnsM="1">
                    <f:content>
                        <core:Title text="Summary Data" />

                        <Label text="Design Target Volume" />
                        <ObjectNumber number="{Quantity}" unit="{UnitCode}" />

                        <Label text="Completed (Cumulative)" design="Bold"/>
                        <ObjectNumber 
                            number="{workSummaryModel>/TotalQuantityDone}" 
                            unit="{UnitCode}" 
                            state="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity'], formatter: '.formatQuantityState'}" />

                        <!-- <Label text="Completion Rate" />
                        <ProgressIndicator
                            percentValue="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity'], formatter: '.formatProgress'}"
                            displayValue="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity', 'UnitCode'], formatter: '.formatProgressDisplay'}"
                            showValue="true"
                            state="Success"
                            height="1.5rem"/> -->
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <!-- ── Section II: Progress Evaluation ──────────────────────────────── -->
            <Panel headerText="II. Progress Evaluation (Target vs Actual)" class="sapUiSmallMarginBottom">
                <VBox width="100%">
                    <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                        <Label text="Completion Rate (Target: {Quantity} {UnitCode})" design="Bold"/>
                        <ObjectStatus 
                            text="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity'], formatter: '.formatPercentage'}" 
                            state="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity'], formatter: '.formatQuantityState'}" />
                    </HBox>
                    
                    <ProgressIndicator
                        percentValue="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity'], formatter: '.formatProgress'}"
                        displayValue="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity', 'UnitCode'], formatter: '.formatProgressDisplay'}"
                        showValue="true"
                        state="{parts: ['workSummaryModel>/TotalQuantityDone', 'Quantity'], formatter: '.formatQuantityState'}"
                        height="1.5rem"/>
                        
                    <l:Grid defaultSpan="L6 M6 S12" class="sapUiMediumMarginTop">
                        <l:content>
                            <VBox>
                                <Label text="Target (Planned)" class="sapUiTinyMarginBottom"/>
                                <ObjectNumber number="{Quantity}" unit="{UnitCode}" state="None" />
                            </VBox>
                            <VBox>
                                <Label text="Actual (Total Done)" class="sapUiTinyMarginBottom"/>
                                <ObjectNumber number="{workSummaryModel>/TotalQuantityDone}" unit="{UnitCode}" state="Success" />
                            </VBox>
                        </l:content>
                    </l:Grid>
                </VBox>
            </Panel>
        </VBox>
    </ScrollContainer>
</core:FragmentDefinition>