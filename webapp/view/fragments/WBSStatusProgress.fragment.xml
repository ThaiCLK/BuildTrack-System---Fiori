<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:suite="sap.suite.ui.commons">
    <suite:ProcessFlow
        id="wbsProcessFlow"
        scrollable="false"
        wheelZoomable="false"
        foldedCorners="true"
        nodes="{pfModel>/nodes}"
        lanes="{pfModel>/lanes}"
        class="sapUiSmallMarginTopBottom">
        <suite:nodes>
            <suite:ProcessFlowNode
                laneId="{pfModel>lane}"
                nodeId="{pfModel>id}"
                title="{pfModel>title}"
                children="{pfModel>children}"
                state="{pfModel>state}"
                stateText="{pfModel>stateText}"
                texts="{pfModel>texts}"
                highlighted="{pfModel>highlighted}"
                focused="{pfModel>focused}" />
        </suite:nodes>
        <suite:lanes>
            <suite:ProcessFlowLaneHeader
                laneId="{pfModel>id}"
                iconSrc="{pfModel>icon}"
                text="{pfModel>label}"
                position="{pfModel>position}" />
        </suite:lanes>
    </suite:ProcessFlow>
</core:FragmentDefinition>
