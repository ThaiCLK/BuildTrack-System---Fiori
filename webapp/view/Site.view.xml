<mvc:View
    controllerName="z.bts.buildtrack551.controller.Site"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar">
    <Page 
        title="Site List — Project: {ProjectName}" 
        showNavButton="true" 
        navButtonPress="onNavBack">
        <content>
            <fb:FilterBar id="siteFilterBar"
                useToolbar="false"
                showGoOnFB="true"
                showClearOnFB="true"
                search="onFilterSearch"
                clear="onFilterClear">
                <fb:filterGroupItems>
                    <fb:FilterGroupItem name="SiteCode" label="Site Code" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteCode"
                                placeholder="Select Site Code"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteCodeRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="SiteName" label="Site Name" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteName"
                                placeholder="Select Site Name"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteNameRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="Status" label="Status" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteStatus"
                                placeholder="Select Status"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteStatusRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="Address" label="Address" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteAddress"
                                placeholder="Select Address"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteAddressRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="CreatedOn" label="Created On" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <DatePicker
                                id="fbSiteCreatedOn"
                                width="100%"
                                displayFormat="dd/MM/yyyy"
                                valueFormat="yyyy-MM-dd"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>

            <Table 
                id="siteTable"
                items="{ToSites}"
                noDataText="No sites found.">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Site List" level="H3"/>
                        <ToolbarSpacer/>
                        <Button 
                            id="btnAddSite"
                            text="Add Site"
                            type="Emphasized"
                            icon="sap-icon://add"
                            press=".onAddSite"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="Site Code" /></Column>
                    <Column><Text text="Site Name" /></Column>
                    <Column><Text text="Address" /></Column>
                    <Column><Text text="Status" /></Column>
                    <Column><Text text="Created On" /></Column>
                    <Column width="8rem"><Text text="Actions" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onSitePress">
                        <cells>
                            <Text text="{SiteCode}" />
                            <Text text="{SiteName}" />
                            <Text text="{Address}" />
                            <ObjectStatus
                                text="{path: 'Status', formatter: '.formatStatusText'}"
                                icon="{ path: 'Status', formatter: '.formatStatusIcon' }"
                                state="{ path: 'Status', formatter: '.formatStatusState' }"
                                inverted="true"/>
                            <Text text="{
                                path: 'CreatedOn',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }" />
                            <HBox>
                                <Button icon="sap-icon://edit"   type="Transparent" press=".onEditSite"   />
                                <Button icon="sap-icon://delete" type="Transparent" press=".onDeleteSite" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>