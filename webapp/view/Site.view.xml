<mvc:View
    controllerName="z.bts.buildtrack551.controller.Site"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:cards="sap.f.cards"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizdata="sap.viz.ui5.data"
    xmlns:feeds="sap.viz.ui5.controls.common.feeds">
    <Page 
        title="{parts: [{path: 'ProjectName'}], formatter: '.formatSiteListTitle'}" 
        showNavButton="true" 
        navButtonPress="onNavBack">
        <content>
            <IconTabBar id="idIconTabBarSite" expanded="true" class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter text="{i18n>siteInfoTab}" key="info" icon="sap-icon://hint">
                        <VBox class="sapUiResponsiveMargin">
                            <f:Card class="sapUiSmallMarginBottom">
                                <f:header>
                                    <cards:Header title="{i18n>overviewInfo}" subtitle="{ProjectCode}" iconSrc="sap-icon://project-definition" />
                                </f:header>
                                <f:content>
                                    <HBox width="100%">
                                        <!-- LEFT: Profile Info -->
                                        <VBox width="40%">
                                            <form:SimpleForm editable="false" layout="ResponsiveGridLayout" 
                                                labelSpanL="5" labelSpanM="5" emptySpanL="0" emptySpanM="0" 
                                                columnsL="1" columnsM="1">
                                                <form:content>
                                                    <core:Title text="{i18n>identification}" />
                                                    <Label text="{i18n>projectName}" />
                                                    <Text text="{ProjectName}" />
                                                    <Label text="{i18n>projectType}" />
                                                    <ObjectStatus text="{path: 'ProjectType', formatter: '.formatTypeText'}" 
                                                        state="{path: 'ProjectType', formatter: '.formatTypeState'}" 
                                                        inverted="true" />
                                                    <Label text="{i18n>status}" />
                                                    <ObjectStatus text="{path: 'Status', formatter: '.formatStatusText'}" 
                                                        class="statusBadgeNoWrap"
                                                        state="{path: 'Status', formatter: '.formatStatusState'}" 
                                                        inverted="true" />

                                                    <core:Title text="{i18n>schedulePlannedVsActual}" />
                                                    <Label text="{i18n>startDate}" />
                                                    <Text text="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
                                                    <Label text="{i18n>endDate}" />
                                                    <Text text="{path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
                                                </form:content>
                                            </form:SimpleForm>
                                        </VBox>

                                        <!-- RIGHT: Burn Down Chart -->
                                        <VBox width="60%" class="sapUiSmallMarginTop">
                                            <viz:VizFrame id="chartBurnDown"
                                                vizType="line"
                                                width="100%"
                                                height="320px">
                                                <viz:dataset>
                                                    <vizdata:FlattenedDataset data="{chartModel>/chartData}">
                                                        <vizdata:dimensions>
                                                            <vizdata:DimensionDefinition name="Date" value="{chartModel>Date}" />
                                                        </vizdata:dimensions>
                                                        <vizdata:measures>
                                                            <vizdata:MeasureDefinition name="Planned" value="{chartModel>Planned}" />
                                                            <vizdata:MeasureDefinition name="Actual" value="{chartModel>Actual}" />
                                                        </vizdata:measures>
                                                    </vizdata:FlattenedDataset>
                                                </viz:dataset>
                                                <viz:feeds>
                                                    <feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date" />
                                                    <feeds:FeedItem uid="valueAxis" type="Measure" values="Planned,Actual" />
                                                </viz:feeds>
                                            </viz:VizFrame>
                                        </VBox>
                                    </HBox>
                                </f:content>
                            </f:Card>

                            <f:Card>
                                <f:header>
                                    <cards:Header title="{i18n>approverInfo}" subtitle="{i18n>approverSectionSubtitle}" iconSrc="sap-icon://manager" />
                                </f:header>
                                <f:content>
                                    <VBox>
                                        <MessageStrip
                                            text="{i18n>approverNotConfigured}"
                                            type="Warning"
                                            showIcon="true"
                                            visible="{= !${approver>/Approver1Id} &amp;&amp; !${approver>/Approver2Id} &amp;&amp; !${approver>/Approver3Id} }"
                                            class="sapUiSmallMargin" />
                                        <form:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4"
                                            visible="{= !!${approver>/Approver1Id} || !!${approver>/Approver2Id} || !!${approver>/Approver3Id} }">
                                            <form:content>
                                                <Label text="{i18n>approver1}" />
                                                <VBox>
                                                    <Label text="{= ${approver>/Approver1Name} || '---' }" design="Bold" class="sapUiTinyMarginBottom" />
                                                    <Text text="{approver>/Approver1Email}" class="sapUiTinyMarginBottom" />
                                                </VBox>
                                                <Label text="{i18n>approver2}" />
                                                <VBox>
                                                    <Label text="{= ${approver>/Approver2Name} || '---' }" design="Bold" class="sapUiTinyMarginBottom" />
                                                    <Text text="{approver>/Approver2Email}" class="sapUiTinyMarginBottom" />
                                                </VBox>
                                                <Label text="{i18n>approver3}" />
                                                <VBox>
                                                    <Label text="{= ${approver>/Approver3Name} || '---' }" design="Bold" class="sapUiTinyMarginBottom" />
                                                    <Text text="{approver>/Approver3Email}" class="sapUiTinyMarginBottom" />
                                                </VBox>
                                            </form:content>
                                        </form:SimpleForm>
                                        <Toolbar style="Clear">
                                            <Button text="{i18n>editApprovers}" icon="sap-icon://edit" press=".onEditApprovers" type="Ghost" 
                                                visible="{= ${userModel>/authLevel} === 99 }"
                                                enabled="{= ${Status} !== 'CLOSED' }" />
                                        </Toolbar>
                                    </VBox>
                                </f:content>
                            </f:Card>
                        </VBox>
                    </IconTabFilter>
                    <IconTabFilter text="Tiến độ Tổng hợp" key="progress" icon="sap-icon://document">
                        <VBox class="sapUiResponsiveMargin">
                            <Panel headerText="Tiến độ Dự án" class="sapUiSmallMarginBottom">
                                <VBox width="100%" class="sapUiSmallMarginBottom sapUiSmallMarginTop">
                                    <HBox justifyContent="SpaceBetween" width="100%">
                                        <Label text="Tiến độ hoàn thành" design="Bold"/>
                                        <Text text="{projectSummaryModel>/ProjectProgressStr}" />
                                    </HBox>
                                    <ProgressIndicator percentValue="{projectSummaryModel>/ProjectProgress}" showValue="false" state="{projectSummaryModel>/ProjectProgressState}" height="1.2rem" width="100%" class="sapUiTinyMarginBottom"/>
                                    <HBox justifyContent="SpaceBetween" width="100%" class="sapUiTinyMarginTop">
                                        <Label text="Tiêu hao Thời gian" design="Bold"/>
                                        <Text text="{projectSummaryModel>/ProjectTimeStr}" />
                                    </HBox>
                                    <ProgressIndicator percentValue="{projectSummaryModel>/ProjectTimePct}" showValue="false" state="{projectSummaryModel>/ProjectTimeState}" height="1.2rem" width="100%" class="sapUiTinyMarginBottom"/>
                                </VBox>
                                <form:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="2" columnsM="2">
                                    <form:content>
                                        <core:Title text="Lịch trình thực tế" />
                                        <Label text="Khởi công" design="Bold"/>
                                        <Text text="{projectSummaryModel>/ProjectActualStartStr}" />
                                        <Label text="Hoàn thành" design="Bold"/>
                                        <Text text="{projectSummaryModel>/ProjectActualEndStr}" />
                                    </form:content>
                                </form:SimpleForm>
                            </Panel>

                            <Panel headerText="Tiến độ chi tiết từng Công trường (Sites)">
                                <Table items="{path: 'projectSummaryModel>/Sites', templateShareable: false}" sticky="HeaderToolbar,ColumnHeaders" width="100%" noDataText="Chưa có dữ liệu tiến độ">
                                    <columns>
                                        <Column>
                                            <Text text="Tên Công trường" />
                                        </Column>
                                        <Column>
                                            <Text text="Tiến độ" />
                                        </Column>
                                        <Column>
                                            <Text text="Thời gian" />
                                        </Column>
                                        <Column hAlign="Begin">
                                            <Text text="Trọng số" />
                                        </Column>
                                        <Column minWidth="180" demandPopin="false">
                                            <Text text="Đánh giá" />
                                        </Column>
                                        <Column>
                                            <Text text="Trạng thái" />
                                        </Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Navigation" press=".onPressSiteProgress">
                                            <cells>
                                                <VBox>
                                                    <Text text="{projectSummaryModel>SiteName}" class="sapMTextBold"/>
                                                    <Text text="{projectSummaryModel>SiteCode}" />
                                                </VBox>
                                                <Text text="{projectSummaryModel>ProgressStr}" />
                                                <Text text="{projectSummaryModel>TimeStr}" />
                                                <Text text="{projectSummaryModel>ContributionStr}" />
                                                <ObjectStatus
                                                    text="{projectSummaryModel>AssessmentText}"
                                                    state="{projectSummaryModel>AssessmentState}"
                                                    class="statusBadgeNoWrap" />
                                                <ObjectStatus text="{path: 'projectSummaryModel>Status', formatter: '.formatStatusText'}" state="{path: 'projectSummaryModel>Status', formatter: '.formatStatusState'}" inverted="true" class="statusBadgeNoWrap" />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </Panel>
                        </VBox>
                    </IconTabFilter>
                    <IconTabFilter text="{i18n>siteList}" key="sites" icon="sap-icon://list">
            <fb:FilterBar id="siteFilterBar"
                useToolbar="false"
                showGoOnFB="true"
                showClearOnFB="true"
                search="onFilterSearch"
                clear="onFilterClear">
                <fb:filterGroupItems>
                    <fb:FilterGroupItem name="SiteCode" label="{i18n>siteCode}" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteCode"
                                placeholder="{i18n>selectSiteCode}"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteCodeRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="SiteName" label="{i18n>siteName}" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteName"
                                placeholder="{i18n>selectSiteName}"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteNameRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteStatus"
                                placeholder="{i18n>selectStatus}"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteStatusRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="Address" label="{i18n>address}" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="fbSiteAddress"
                                placeholder="{i18n>selectAddress}"
                                showValueHelp="true"
                                valueHelpRequest="onValueHelpSiteAddressRequest"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem name="CreatedOn" label="{i18n>createdOn}" groupName="Basic" visibleInFilterBar="true">
                        <fb:control>
                            <DatePicker
                                id="fbSiteCreatedOn"
                                width="100%"
                                displayFormat="dd/MM/yyyy"
                                valueFormat="yyyy-MM-dd"/>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>

            <Table 
                id="siteTable"
                items="{path: 'ToSites', sorter: {path: 'SiteCode', descending: false}}"
                fixedLayout="false"
                noDataText="{i18n>noSitesFound}">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>siteList}" level="H3"/>
                        <ToolbarSpacer/>
                        <Button 
                            id="btnAddSite"
                            text="{i18n>addSite}"
                            type="Emphasized"
                            icon="sap-icon://add"
                            press=".onAddSite"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>siteCode}" /></Column>
                    <Column><Text text="{i18n>siteName}" /></Column>
                    <Column><Text text="{i18n>address}" /></Column>
                    <Column><Text text="{i18n>status}" /></Column>
                    <Column><Text text="{i18n>createdOn}" /></Column>
                    <Column width="8rem"><Text text="{i18n>actions}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onSitePress">
                        <cells>
                            <Text text="{SiteCode}" />
                            <Text text="{SiteName}" />
                            <Text text="{Address}" />
                            <ObjectStatus
                                text="{path: 'Status', formatter: '.formatStatusText'}"
                                class="statusBadgeNoWrap"
                                state="{ path: 'Status', formatter: '.formatStatusState' }"
                                inverted="true"/>
                            <Text text="{
                                path: 'CreatedOn',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }" />
                            <HBox>
                                <Button icon="sap-icon://edit"   type="Transparent" press=".onEditSite" tooltip="{i18n>editSite}" />
                                <Button icon="sap-icon://decline" type="Transparent" press=".onCloseSite" tooltip="{i18n>closeSite}" enabled="{= ${Status} === 'IN_PROGRESS' }" />
                                <Button icon="sap-icon://delete" type="Transparent" press=".onDeleteSite" tooltip="{i18n>deleteSite}" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>