<mvc:View controllerName="z.bts.buildtrack.controller.ProjectManagement"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">

    <Page id="pageProjectList" title="{i18n>title}">
        <content>
            <Table id="projectTable"
                inset="false"
                items="{
                    path: '/zbt_project',
                    sorter: { path: 'project_code' }
                }">
                
                <headerToolbar>
                    <OverflowToolbar id="otbSubheader">
                        <Title id="tableHeader" text="Project Database ({= ${/zbt_project}.length })" level="H2"/>
                        <ToolbarSpacer id="toolbarSpacer"/>
                        <SearchField 
    id="searchProject" 
    width="20%" 
    placeholder="Find..." 
    search=".onSearch" />  <Button 
    id="btnCreateProject" 
    text="Create Project" 
    type="Emphasized" 
    icon="sap-icon://add"
    press=".onPressCreate" />
                        <Button id="btnSortProject" icon="sap-icon://sort" type="Transparent"/>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column id="colProjectCode" width="12em">
                        <Text id="txtColProjectCode" text="Project ID" />
                    </Column>
                    <Column id="colProjectName" minScreenWidth="Tablet" demandPopin="true">
                        <Text id="txtColProjectName" text="Project Name" />
                    </Column>
                    <Column id="colProjectType" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                        <Text id="txtColProjectType" text="Type" />
                    </Column>
                    <Column id="colStartDate" hAlign="End">
                        <Text id="txtColStartDate" text="Start Date" />
                    </Column>
                    <Column id="colEndDate" hAlign="End">
                        <Text id="txtColEndDate" text="Est. End Date" />
                    </Column>
                    <Column id="colStatus" hAlign="Center">
                        <Text id="txtColStatus" text="Status" />
                    </Column>
                    <Column id="colAction" width="5em">
                        <Text id="txtColAction" text="Action" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="cliProjectTemplate" vAlign="Middle" type="Navigation" press=".onPressProject">
                        <cells>
                            <ObjectIdentifier id="objProjectCode" title="{project_code}" />

                            <Text id="txtProjectName" text="{project_name}" />

                            <ObjectStatus id="objProjectType" text="{project_type}" state="Information" inverted="true" />

                            <Text id="txtStartDate" text="{
                                path: 'start_date',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }" />

                            <Text id="txtEndDate" text="{
                                path: 'end_date',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }" />

                            <ObjectStatus id="objStatus"
                                text="{status}"
                                state="{= ${status} === 'COMPLETED' ? 'Success' : (${status} === 'RUNNING' ? 'Indication05' : 'None') }"
                                icon="{= ${status} === 'COMPLETED' ? 'sap-icon://accept' : 'sap-icon://process' }" />
                            
                            <Button id="btnEditProject" icon="sap-icon://edit" type="Transparent" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>