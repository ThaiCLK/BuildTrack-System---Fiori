<mvc:View controllerName="z.bts.buildtrack.controller.ProjectManagement"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar">

    <Page id="pageProjectList" showNavButton="true" navButtonPress=".onNavBack"
          showHeader="false">
        <content>
            <VBox width="100%">
                <fb:FilterBar id="projectFilterBar"
                    useToolbar="false"
                    showGoOnFB="true"
                    search="onFilterSearch"
                    clear="onFilterClear"
                    showClearOnFB="true">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem name="ProjectCode" label="Project Code" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="fbProjectCode" placeholder="e.g. PRJ-2024-001"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="ProjectName" label="Project Name" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="fbProjectName" placeholder="e.g. Aurora"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="Status" label="Status" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <ComboBox id="fbStatus" placeholder="Select Status" items="{vh>/statusItems}">
                                    <core:Item key="{vh>key}" text="{vh>text}"/>
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="ProjectType" label="Project Type" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <ComboBox id="fbType" placeholder="Select Type" items="{vh>/typeItems}">
                                    <core:Item key="{vh>key}" text="{vh>text}"/>
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="StartDate" label="Start Date" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <DatePicker id="fbStartDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="EndDate" label="End Date" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <DatePicker id="fbEndDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>

                <Table id="projectTable"
                    inset="false"
                    growing="true"
                    growingThreshold="20"
                    alternateRowColors="true"
                    items="{ path: 'pm>/projects' }">

                <headerToolbar>
                    <OverflowToolbar id="otbSubheader" style="Clear">
                        <!-- Back chevron + title -->
                        <Button icon="sap-icon://nav-back" type="Transparent" press=".onNavBack"
                                tooltip="Back to Dashboard"/>
                        <Title id="tableHeader" text="Project List" level="H2"/>
                        <ToolbarSpacer id="toolbarSpacer"/>
                        <Button
                            id="btnCreateProject"
                            text="Create Project"
                            type="Emphasized"
                            icon="sap-icon://add"
                            press=".onPressCreate"/>
                        <Button id="btnSortProject" icon="sap-icon://sort" type="Transparent"
                                tooltip="Sort"/>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column id="colProjectCode" width="10rem">
                        <Text id="txtColProjectCode" text="Project Code"/>
                    </Column>
                    <Column id="colProjectName" minScreenWidth="Tablet" demandPopin="true">
                        <Text id="txtColProjectName" text="Project Name"/>
                    </Column>
                    <Column id="colProjectType" width="9rem" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                        <Text id="txtColProjectType" text="Type"/>
                    </Column>
                    <Column id="colStartDate" width="8rem" hAlign="End">
                        <Text id="txtColStartDate" text="Start Date"/>
                    </Column>
                    <Column id="colEndDate" width="9rem" hAlign="End">
                        <Text id="txtColEndDate" text="Est. End Date"/>
                    </Column>
                    <Column id="colStatus" width="10rem" hAlign="Center">
                        <Text id="txtColStatus" text="Status"/>
                    </Column>
                    <Column id="colAction" width="7rem" hAlign="Center">
                        <Text id="txtColAction" text="Actions"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="cliProjectTemplate" vAlign="Middle"
                                    type="Navigation" press=".onPressProject">
                        <cells>
                            <!-- Project Code: bold identifier -->
                            <ObjectIdentifier id="objProjectCode"
                                title="{pm>ProjectCode}"
                                titleActive="false"/>

                            <!-- Project Name -->
                            <ObjectIdentifier id="objProjectName"
                                title="{pm>ProjectName}"
                                titleActive="false"/>

                            <!-- Type badge — icon & colour via formatter (avoids XML whitespace issues) -->
                            <ObjectStatus id="objProjectType"
                                text="{pm>ProjectType}"
                                icon="{ path: 'pm>ProjectType', formatter: '.formatTypeIcon' }"
                                state="{ path: 'pm>ProjectType', formatter: '.formatTypeState' }"
                                inverted="true"/>

                            <!-- Start Date -->
                            <Text id="txtStartDate" text="{
                                path: 'pm>StartDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }"/>

                            <!-- End Date — highlight overdue in red -->
                            <ObjectStatus id="objEndDate"
                                text="{
                                    path: 'pm>EndDate',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: { pattern: 'dd/MM/yyyy' }
                                }"
                                state="None"/>

                            <!-- Status badge with semantic colours -->
                            <ObjectStatus id="objStatus"
                                text="{path: 'pm>Status', formatter: '.formatStatusText'}"
                                icon="{= ${pm>Status} === 'IN_PROGRESS' ? 'sap-icon://status-positive'  :
                                    ${pm>Status} === 'PLANNING' ? 'sap-icon://status-in-process' :
                                    ${pm>Status} === 'CLOSED'   ? 'sap-icon://status-negative'   :
                                                                    'sap-icon://status-inactive' }"
                                state="{= ${pm>Status} === 'IN_PROGRESS' ? 'Success'     :
                                     ${pm>Status} === 'PLANNING' ? 'Warning'     :
                                     ${pm>Status} === 'CLOSED'   ? 'Error'       :
                                                                    'None' }"
                                inverted="true"/>

                            <!-- Actions -->
                            <HBox alignItems="Center" justifyContent="Center">
                                <Button icon="sap-icon://edit"
                                        type="Transparent"
                                        tooltip="Edit Project"
                                        press=".onEditProject"/>
                                <Button icon="sap-icon://delete"
                                        type="Transparent"
                                        tooltip="Delete Project"
                                        press=".onDeleteProject"/>
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>

                <noData>
                    <IllustratedMessage
                        illustrationType="sapIllus-NoData"
                        title="No Projects Found"
                        description="Create a new project or adjust your search."/>
                </noData>

                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>