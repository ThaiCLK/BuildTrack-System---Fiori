<mvc:View controllerName="z.bts.buildtrack551.controller.ProjectManagement"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar">

    <Page id="pageProjectList" showNavButton="true" navButtonPress=".onNavBack"
          showHeader="false">
        <content>
            <VBox width="100%">
                <fb:FilterBar id="projectFilterBar"
                    useToolbar="false"
                    showGoOnFB="true"
                    search="onFilterSearch"
                    clear="onFilterClear"
                    showClearOnFB="true">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem name="ProjectCode" label="{i18n>projectCode}" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="fbProjectCode"
                                    placeholder="{i18n>selectProjectCode}"
                                    showValueHelp="true"
                                    valueHelpRequest="onValueHelpProjectCodeRequest"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="ProjectName" label="{i18n>projectName}" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="fbProjectName"
                                    placeholder="{i18n>selectProjectName}"
                                    showValueHelp="true"
                                    valueHelpRequest="onValueHelpProjectNameRequest"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="fbStatus"
                                    placeholder="{i18n>selectStatus}"
                                    showValueHelp="true"
                                    valueHelpRequest="onValueHelpStatusRequest"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="ProjectType" label="{i18n>projectType}" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="fbType"
                                    placeholder="{i18n>selectType}"
                                    showValueHelp="true"
                                    valueHelpRequest="onValueHelpTypeRequest"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="StartDate" label="{i18n>startDate}" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <DatePicker id="fbStartDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd" afterRendering=".onDatePickerAfterRendering"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="EndDate" label="{i18n>endDate}" groupName="Basic" visibleInFilterBar="true">
                            <fb:control>
                                <DatePicker id="fbEndDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd" afterRendering=".onDatePickerAfterRendering"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>

                <Table id="projectTable"
                    inset="false"
                    growing="true"
                    growingThreshold="20"
                    alternateRowColors="true"
                    items="{ path: 'pm>/projects', sorter: { path: 'ProjectCode', descending: false } }">

                <headerToolbar>
                    <OverflowToolbar id="otbSubheader" style="Clear">
                        <!-- Back chevron + title -->
                        <Button icon="sap-icon://nav-back" type="Transparent" press=".onNavBack"
                                tooltip="{i18n>backToDashboard}"/>
                        <Title id="tableHeader" text="{i18n>projectList}" level="H2"/>
                        <ToolbarSpacer id="toolbarSpacer"/>
                        <Button
                            id="btnCreateProject"
                            text="{i18n>createProject}"
                            type="Emphasized"
                            icon="sap-icon://add"
                            press=".onPressCreate"/>
                        <!-- <Button id="btnSortProject" icon="sap-icon://sort" type="Transparent"
                                tooltip="{i18n>sort}"/> -->
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column id="colProjectCode" width="10rem">
                        <Text id="txtColProjectCode" text="{i18n>projectCode}"/>
                    </Column>
                    <Column id="colProjectName" minScreenWidth="Tablet" demandPopin="true">
                        <Text id="txtColProjectName" text="{i18n>projectName}"/>
                    </Column>
                    <Column id="colProjectType" width="9rem" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                        <Text id="txtColProjectType" text="{i18n>type}"/>
                    </Column>
                    <Column id="colStartDate" width="8rem" hAlign="End">
                        <Text id="txtColStartDate" text="{i18n>startDate}"/>
                    </Column>
                    <Column id="colEndDate" width="9rem" hAlign="End">
                        <Text id="txtColEndDate" text="{i18n>estEndDate}"/>
                    </Column>
                    <Column id="colStatus" width="10rem" hAlign="Center">
                        <Text id="txtColStatus" text="{i18n>status}"/>
                    </Column>
                    <Column id="colAction" width="7rem" hAlign="Center">
                        <Text id="txtColAction" text="{i18n>actions}"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="cliProjectTemplate" vAlign="Middle"
                                    type="Navigation" press=".onPressProject">
                        <cells>
                            <!-- Project Code: bold identifier -->
                            <ObjectIdentifier id="objProjectCode"
                                title="{pm>ProjectCode}"
                                titleActive="false"/>

                            <!-- Project Name -->
                            <ObjectIdentifier id="objProjectName"
                                title="{pm>ProjectName}"
                                titleActive="false"/>

                            <!-- Type badge — icon & colour via formatter (avoids XML whitespace issues) -->
                            <ObjectStatus id="objProjectType"
                                text="{ path: 'pm>ProjectType', formatter: '.formatTypeText' }"
                                icon="{ path: 'pm>ProjectType', formatter: '.formatTypeIcon' }"
                                state="{ path: 'pm>ProjectType', formatter: '.formatTypeState' }"
                                inverted="true"/>

                            <!-- Start Date -->
                            <Text id="txtStartDate" text="{
                                path: 'pm>StartDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }"/>

                            <!-- End Date — highlight overdue in red -->
                            <ObjectStatus id="objEndDate"
                                text="{
                                    path: 'pm>EndDate',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: { pattern: 'dd/MM/yyyy' }
                                }"
                                state="None"/>

                            <!-- Status badge with semantic colours -->
                            <ObjectStatus id="objStatus"
                                text="{path: 'pm>Status', formatter: '.formatStatusText'}"
                                icon="{= ${pm>Status} === 'IN_PROGRESS' ? 'sap-icon://status-positive'  :
                                    ${pm>Status} === 'PLANNING' ? 'sap-icon://status-in-process' :
                                    ${pm>Status} === 'CLOSED'   ? 'sap-icon://status-negative'   :
                                                                    'sap-icon://status-inactive' }"
                                state="{= ${pm>Status} === 'IN_PROGRESS' ? 'Success'     :
                                     ${pm>Status} === 'PLANNING' ? 'Warning'     :
                                     ${pm>Status} === 'CLOSED'   ? 'None'        :
                                                                    'None' }"
                                inverted="true"/>

                            <!-- Actions -->
                            <HBox alignItems="Center" justifyContent="Center">
                                <Button icon="sap-icon://edit"
                                        type="Transparent"
                                        tooltip="{i18n>editProject}"
                                        press=".onEditProject"/>
                                <Button icon="sap-icon://delete"
                                        type="Transparent"
                                        tooltip="{i18n>deleteProject}"
                                        press=".onDeleteProject"/>
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>

                <noData>
                    <IllustratedMessage
                        illustrationType="sapIllus-NoData"
                        title="{i18n>noProjectsFound}"
                        description="{i18n>noProjectsFoundDesc}"/>
                </noData>

                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>