<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0" xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx"
    xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata"
    xmlns:sap="http://www.sap.com/Protocols/SAPData">
    <edmx:DataServices m:DataServiceVersion="2.0">
        <Schema Namespace="Z_BTS_SRV" xml:lang="en" xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

            <EntityType Name="Project">
                <Key>
                    <PropertyRef Name="project_id" />
                </Key>
                <Property Name="project_id" Type="Edm.Guid" Nullable="false" sap:label="Project UUID" />
                <Property Name="project_code" Type="Edm.String" MaxLength="30" sap:label="Project Code" />
                <Property Name="project_name" Type="Edm.String" MaxLength="100" sap:label="Project Name" />
                <Property Name="project_type" Type="Edm.String" MaxLength="20" sap:label="Type" />
                <Property Name="start_date" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Start Date" />
                <Property Name="end_date" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="End Date" />
                <Property Name="status" Type="Edm.String" MaxLength="10" sap:label="Status" />
                <Property Name="created_by" Type="Edm.String" MaxLength="12" sap:label="Created By" />
                <Property Name="created_on" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Created On" />
                <Property Name="created_at" Type="Edm.Time" Precision="0" sap:label="Created At" />
                <Property Name="updated_by" Type="Edm.String" MaxLength="12" sap:label="Updated By" />
                <Property Name="updated_on" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Updated On" />
                <Property Name="updated_at" Type="Edm.Time" Precision="0" sap:label="Updated At" />
                <NavigationProperty Name="to_Sites" Relationship="Z_BTS_SRV.Proj_to_Site" FromRole="FromProj" ToRole="ToSite" />
            </EntityType>

            <EntityType Name="Site">
                <Key>
                    <PropertyRef Name="site_id" />
                </Key>
                <Property Name="site_id" Type="Edm.Guid" Nullable="false" sap:label="Site UUID" />
                <Property Name="project_id" Type="Edm.Guid" sap:label="Project UUID" />
                <Property Name="site_code" Type="Edm.String" MaxLength="30" sap:label="Site Code" />
                <Property Name="site_name" Type="Edm.String" MaxLength="100" sap:label="Site Name" />
                <Property Name="address" Type="Edm.String" MaxLength="100" sap:label="Address" />
                <Property Name="status" Type="Edm.String" MaxLength="10" sap:label="Status" />
                <Property Name="created_by" Type="Edm.String" MaxLength="12" sap:label="Created By" />
                <Property Name="created_on" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Created On" />
                <Property Name="created_at" Type="Edm.Time" Precision="0" sap:label="Created At" />
                <Property Name="updated_by" Type="Edm.String" MaxLength="12" sap:label="Updated By" />
                <Property Name="updated_on" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Updated On" />
                <Property Name="updated_at" Type="Edm.Time" Precision="0" sap:label="Updated At" />
                <NavigationProperty Name="to_WBS" Relationship="Z_BTS_SRV.Site_to_WBS" FromRole="FromSite" ToRole="ToWBS" />
            </EntityType>

            <EntityType Name="WBS">
                <Key>
                    <PropertyRef Name="wbs_id" />
                </Key>
                <Property Name="wbs_id" Type="Edm.Guid" Nullable="false" sap:label="WBS UUID" />
                <Property Name="site_id" Type="Edm.Guid" sap:label="Site UUID" />
                <Property Name="wbs_name" Type="Edm.String" MaxLength="200" sap:label="WBS Name" />
                <Property Name="wbs_code" Type="Edm.String" MaxLength="30" sap:label="WBS Code" />
                <Property Name="parent_id" Type="Edm.Guid" sap:label="Parent WBS UUID" />
                <Property Name="start_date" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Plan Start" />
                <Property Name="end_date" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Plan End" />
                <Property Name="start_actual" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Actual Start" />
                <Property Name="end_actual" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Actual End" />
                <Property Name="quantity" Type="Edm.Decimal" Precision="13" Scale="3" sap:label="Quantity" />
                <Property Name="unit_code" Type="Edm.String" MaxLength="3" sap:label="Unit" />
                <Property Name="status" Type="Edm.String" MaxLength="50" sap:label="Status" />
                <Property Name="created_by" Type="Edm.String" MaxLength="12" sap:label="Created By" />
                <Property Name="created_on" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Created On" />
                <Property Name="created_at" Type="Edm.Time" Precision="0" sap:label="Created At" />
                <Property Name="updated_by" Type="Edm.String" MaxLength="12" sap:label="Updated By" />
                <Property Name="updated_on" Type="Edm.DateTime" Precision="0" DisplayFormat="Date" sap:label="Updated On" />
                <Property Name="updated_at" Type="Edm.Time" Precision="0" sap:label="Updated At" />
                
                <NavigationProperty Name="SubWBS" Relationship="Z_BTS_SRV.WBS_to_SubWBS" FromRole="ParentWBS" ToRole="ChildWBS" />
            </EntityType>

            <Association Name="Proj_to_Site">
                <End Role="FromProj" Type="Z_BTS_SRV.Project" Multiplicity="1" />
                <End Role="ToSite" Type="Z_BTS_SRV.Site" Multiplicity="*" />
                <ReferentialConstraint>
                    <Principal Role="FromProj"><PropertyRef Name="project_id" /></Principal>
                    <Dependent Role="ToSite"><PropertyRef Name="project_id" /></Dependent>
                </ReferentialConstraint>
            </Association>

            <Association Name="Site_to_WBS">
                <End Role="FromSite" Type="Z_BTS_SRV.Site" Multiplicity="1" />
                <End Role="ToWBS" Type="Z_BTS_SRV.WBS" Multiplicity="*" />
                <ReferentialConstraint>
                    <Principal Role="FromSite"><PropertyRef Name="site_id" /></Principal>
                    <Dependent Role="ToWBS"><PropertyRef Name="site_id" /></Dependent>
                </ReferentialConstraint>
            </Association>

            <Association Name="WBS_to_SubWBS">
                <End Role="ParentWBS" Type="Z_BTS_SRV.WBS" Multiplicity="0..1" />
                <End Role="ChildWBS" Type="Z_BTS_SRV.WBS" Multiplicity="*" />
                <ReferentialConstraint>
                    <Principal Role="ParentWBS"><PropertyRef Name="wbs_id" /></Principal>
                    <Dependent Role="ChildWBS"><PropertyRef Name="parent_id" /></Dependent>
                </ReferentialConstraint>
            </Association>

            <EntityContainer Name="Z_BTS_SRV_Entities" m:IsDefaultEntityContainer="true">
                <EntitySet Name="zbt_project" EntityType="Z_BTS_SRV.Project" />
                <EntitySet Name="zbt_site" EntityType="Z_BTS_SRV.Site" />
                <EntitySet Name="zbt_wbs" EntityType="Z_BTS_SRV.WBS" />

                <AssociationSet Name="Proj_to_Site_Set" Association="Z_BTS_SRV.Proj_to_Site">
                    <End Role="FromProj" EntitySet="zbt_project" />
                    <End Role="ToSite" EntitySet="zbt_site" />
                </AssociationSet>
                <AssociationSet Name="Site_to_WBS_Set" Association="Z_BTS_SRV.Site_to_WBS">
                    <End Role="FromSite" EntitySet="zbt_site" />
                    <End Role="ToWBS" EntitySet="zbt_wbs" />
                </AssociationSet>
            </EntityContainer>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>